---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getMikanResourcesByKind, groupMikanResourcesByCategory } from "@/data/mikan";
import { url } from "@/utils/url-utils";

const resources = getMikanResourcesByKind("tool");
const groups = groupMikanResourcesByCategory(resources);

function getHost(target: string) {
	try {
		return new URL(target).host.replace(/^www\./, "");
	} catch {
		return target;
	}
}
---

<MainGridLayout title="工具导航" description="长期反复使用的网站、平台与文档入口">
	<section class="card-base px-6 py-7 sm:px-8 mb-4">
		<a href={url("/resources/")} class="mb-5 inline-flex items-center gap-1 text-sm text-30 transition-colors hover:text-(--primary)">
			<Icon is:inline name="material-symbols:arrow-back-rounded" />
			收藏总览
		</a>
		<div class="flex items-start gap-4">
			<div class="h-11 w-11 shrink-0 rounded-2xl bg-(--primary) text-white dark:text-black/70 flex items-center justify-center">
				<Icon is:inline name="material-symbols:rocket-launch-rounded" class="text-2xl" />
			</div>
			<div>
				<h1 class="text-2xl font-bold text-90">工具导航</h1>
				<p class="mt-2 text-sm leading-6 text-50">这里收藏的是“站点本身值得长期使用”的入口。按分类停靠，下一次需要时不必重新搜索。</p>
			</div>
		</div>
		<nav class="mt-6 flex flex-wrap gap-2" aria-label="工具分类">
			<a href="#tool-groups" class="tool-pill tool-pill--active">全部 <span>{resources.length}</span></a>
			{groups.map((group, index) => (
				<a href={`#tool-group-${index}`} class="tool-pill">{group.category} <span>{group.count}</span></a>
			))}
		</nav>
	</section>

	<div id="tool-groups" class="grid gap-5">
		{groups.map((group, groupIndex) => (
			<section id={`tool-group-${groupIndex}`} class="card-base scroll-mt-24 p-5 sm:p-6">
				<div class="mb-4 flex items-center justify-between gap-4">
					<div class="flex items-center gap-3">
						<span class="h-2.5 w-2.5 rounded-full bg-(--primary) shadow-[0_0_0_5px_color-mix(in_srgb,var(--primary)_12%,transparent)]"></span>
						<h2 class="text-lg font-bold text-90">{group.category}</h2>
					</div>
					<span class="text-xs text-30">{group.count} 个入口</span>
				</div>
				<div class="grid gap-3 md:grid-cols-2">
					{group.items.map((item, itemIndex) => (
						<a
							href={item.url}
							target="_blank"
							rel="noopener noreferrer"
							class="tool-card group rounded-2xl border border-(--line-divider) bg-black/[0.015] p-4 dark:bg-white/[0.025] onload-animation"
							style={`animation-delay: calc(var(--content-delay) + ${(groupIndex * 2 + itemIndex) * 45}ms);`}
						>
							<div class="flex items-start justify-between gap-3">
								<div class="min-w-0">
									<div class="flex flex-wrap items-center gap-2">
										<h3 class="font-bold text-90 transition-colors group-hover:text-(--primary)">{item.title}</h3>
										{item.featured && <span class="rounded-md bg-(--primary)/10 px-2 py-0.5 text-[0.68rem] font-medium text-(--primary)">常用</span>}
									</div>
									<p class="mt-1 truncate text-xs text-30">{getHost(item.url)}</p>
								</div>
								<Icon is:inline name="material-symbols:arrow-outward-rounded" class="shrink-0 text-xl text-(--primary) opacity-60 transition-all group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:opacity-100" />
							</div>
							<p class="mt-3 text-sm leading-6 text-50">{item.note}</p>
							<div class="mt-4 flex flex-wrap gap-1.5">
								{item.tags.map((tag) => <span class="rounded-md bg-black/5 px-2 py-1 text-[0.68rem] text-50 dark:bg-white/10">#{tag}</span>)}
							</div>
						</a>
					))}
				</div>
			</section>
		))}
	</div>
</MainGridLayout>

<style>
	.tool-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		border: 1px solid var(--line-divider);
		border-radius: 999px;
		padding: 0.45rem 0.8rem;
		font-size: 0.78rem;
		color: var(--content-meta);
		transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
	}

	.tool-pill span {
		font-size: 0.68rem;
		opacity: 0.7;
	}

	.tool-pill:hover,
	.tool-pill--active {
		border-color: color-mix(in srgb, var(--primary) 45%, transparent);
		background: color-mix(in srgb, var(--primary) 10%, transparent);
		color: var(--primary);
	}

	.tool-card {
		transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
	}

	.tool-card:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--primary) 38%, transparent);
		box-shadow: 0 12px 28px color-mix(in srgb, var(--primary) 9%, transparent);
	}
</style>
