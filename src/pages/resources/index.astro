---
import ContentGridLayout from "@/layouts/ContentGridLayout.astro";
import { url } from "@/utils/url-utils";

const targetUrl = url("/resources/tools/");
const refreshContent = "0; url=" + targetUrl;
---

<ContentGridLayout title="收藏" description="收藏入口已精简为工具导航和摘录收藏">
	<meta slot="head" http-equiv="refresh" content={refreshContent} />
	<section class="resources-page card-base relative overflow-hidden px-5 py-7 sm:px-8 sm:py-9">
		<div class="relative z-10">
			<p class="text-sm leading-6 text-50">该入口已精简，正在前往工具导航。</p>
			<a class="mt-4 inline-flex rounded-xl bg-(--primary) px-4 py-2 text-sm font-bold text-white" href={targetUrl}>
				打开工具导航
			</a>
		</div>
	</section>
</ContentGridLayout>
