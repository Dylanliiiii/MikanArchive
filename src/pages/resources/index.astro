---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getMikanResources } from "@/data/mikan";

const resources = getMikanResources();
const categories = [...new Set(resources.map((item) => item.category))].sort();
---

<MainGridLayout title="收藏" description="资源、工具、文档和灵感收藏">
	<section class="card-base px-8 py-6 mb-4">
		<div class="flex items-center gap-3">
			<div class="h-9 w-9 rounded-xl bg-(--primary) text-white dark:text-black/70 flex items-center justify-center">
				<Icon is:inline name="material-symbols:bookmark-heart-rounded" class="text-2xl" />
			</div>
			<div>
				<h1 class="text-2xl font-bold text-90">收藏</h1>
				<p class="mt-1 text-sm text-30">资源、工具、文档和灵感，按再次打开时能看懂的方式保存。</p>
			</div>
		</div>
		<div class="mt-5 flex flex-wrap gap-2">
			<span class="rounded-lg bg-(--primary)/10 px-3 py-1.5 text-sm text-(--primary)">全部 {resources.length}</span>
			{categories.map((category) => <span class="rounded-lg bg-black/5 dark:bg-white/10 px-3 py-1.5 text-sm text-50">{category}</span>)}
		</div>
	</section>

	<div class="grid gap-4 md:grid-cols-2">
		{resources.map((item, index) => (
			<a
				href={item.url}
				target="_blank"
				rel="noopener noreferrer"
				class="card-base group p-5 onload-animation"
				style={`animation-delay: calc(var(--content-delay) + ${index * 50}ms);`}
			>
				<div class="flex items-start justify-between gap-4">
					<div class="min-w-0">
						<div class="flex items-center gap-2">
							<h2 class="text-lg font-bold text-90 group-hover:text-(--primary) transition-colors truncate">{item.title}</h2>
							{item.featured && <span class="rounded-md bg-(--primary)/10 px-2 py-0.5 text-xs text-(--primary)">推荐</span>}
						</div>
						<p class="mt-2 text-sm leading-6 text-50">{item.note}</p>
					</div>
					<Icon is:inline name="material-symbols:arrow-outward-rounded" class="text-xl text-(--primary) shrink-0 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all" />
				</div>
				<div class="mt-4 flex flex-wrap gap-1.5">
					<span class="rounded-md bg-black/5 dark:bg-white/10 px-2 py-1 text-[0.7rem] text-50">{item.category}</span>
					{item.tags.map((tag) => <span class="rounded-md bg-black/5 dark:bg-white/10 px-2 py-1 text-[0.7rem] text-50">#{tag}</span>)}
				</div>
			</a>
		))}
	</div>
</MainGridLayout>
