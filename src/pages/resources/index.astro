---
import ResourceCard from "@/components/cards/ResourceCard.astro";
import { SearchDialog } from "@/components/search/SearchDialog";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getResources } from "../_data";

const resources = await getResources();
const categories = [...new Set(resources.map((item) => item.category))];
const tags = [...new Set(resources.flatMap((item) => item.tags ?? []))];
const searchItems = resources.map((item) => ({
  title: item.title,
  description: item.note,
  href: item.url,
  category: item.category,
  tags: item.tags
}));
---

<BaseLayout title="收藏" description="工具、文档、教程和灵感收藏">
  <section class="container page-shell">
    <div class="section-title">
      <div>
        <h1 class="text-3xl font-black tracking-normal sm:text-4xl">收藏</h1>
        <p>按主题保存资源，也保存当初留下它的理由。</p>
      </div>
      <SearchDialog client:load items={searchItems} />
    </div>

    <div class="mb-6 grid gap-4 lg:grid-cols-[0.8fr_1.2fr]">
      <div class="surface p-4">
        <p class="text-sm font-semibold">分类摘要</p>
        <div class="mt-3 flex flex-wrap gap-2">
          {categories.map((category) => <a class="badge bg-secondary/15 text-sky-700" href={`#category-${category}`}>{category}</a>)}
        </div>
      </div>
      <div class="surface p-4">
        <p class="text-sm font-semibold">标签索引</p>
        <div class="mt-3 flex flex-wrap gap-2">
          {tags.map((tag) => <span class="badge">#{tag}</span>)}
        </div>
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {resources.map((resource) => <ResourceCard {...resource} />)}
    </div>
  </section>
</BaseLayout>
