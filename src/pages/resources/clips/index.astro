---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getMikanResourcesByKind, groupMikanResourcesByCategory } from "@/data/mikan";
import { url } from "@/utils/url-utils";

const resources = getMikanResourcesByKind("clip");
const groups = groupMikanResourcesByCategory(resources);
---

<MainGridLayout title="摘录收藏" description="为具体问题与知识点留下可回溯的网页线索">
	<section class="card-base px-6 py-7 sm:px-8 mb-4">
		<a href={url("/resources/")} class="mb-5 inline-flex items-center gap-1 text-sm text-30 transition-colors hover:text-(--primary)">
			<Icon is:inline name="material-symbols:arrow-back-rounded" />
			收藏总览
		</a>
		<div class="flex items-start gap-4">
			<div class="clip-heading-icon h-11 w-11 shrink-0 rounded-2xl flex items-center justify-center">
				<Icon is:inline name="material-symbols:bookmarks-rounded" class="text-2xl" />
			</div>
			<div>
				<h1 class="text-2xl font-bold text-90">摘录收藏</h1>
				<p class="mt-2 text-sm leading-6 text-50">这里收藏的是“某篇网页为什么有用”。来源、适用场景和收藏日期会一起留下，让知识线索能被再次理解。</p>
			</div>
		</div>
		<div class="mt-6 flex flex-wrap gap-2">
			<span class="rounded-full bg-[#f2a36b]/12 px-3 py-1.5 text-xs font-medium text-[#c87350] dark:text-[#f0ad8c]">全部 {resources.length}</span>
			{groups.map((group) => <span class="rounded-full bg-black/5 px-3 py-1.5 text-xs text-50 dark:bg-white/10">{group.category} {group.count}</span>)}
		</div>
	</section>

	<div class="grid gap-5">
		{groups.map((group) => (
			<section class="card-base overflow-hidden p-5 sm:p-6">
				<div class="mb-4 flex items-center gap-3">
					<span class="clip-category-mark"></span>
					<h2 class="text-lg font-bold text-90">{group.category}</h2>
					<span class="text-xs text-30">{group.count} 条</span>
				</div>
				<div class="divide-y divide-(--line-divider)">
					{group.items.map((item, index) => (
						<article class="clip-item group py-5 first:pt-1 last:pb-1 onload-animation" style={`animation-delay: calc(var(--content-delay) + ${index * 55}ms);`}>
							<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
								<div class="min-w-0 flex-1">
									<div class="flex flex-wrap items-center gap-2">
										{item.sourceName && <span class="rounded-md bg-[#f2a36b]/12 px-2 py-1 text-[0.68rem] font-semibold text-[#c87350] dark:text-[#f0ad8c]">{item.sourceName}</span>}
										{item.addedAt && <time datetime={item.addedAt} class="text-xs text-30">收藏于 {item.addedAt}</time>}
									</div>
									<h3 class="mt-2 text-lg font-bold text-90 transition-colors group-hover:text-(--primary)">{item.title}</h3>
									<p class="mt-2 text-sm leading-6 text-50">{item.note}</p>
									{item.scenario && (
										<div class="clip-scenario mt-3 flex items-start gap-2 rounded-xl px-3 py-2.5 text-sm leading-5 text-50">
											<Icon is:inline name="material-symbols:lightbulb-rounded" class="mt-0.5 shrink-0 text-lg text-[#d58a59]" />
											<span><strong class="font-semibold text-70">适用场景：</strong>{item.scenario}</span>
										</div>
									)}
									<div class="mt-3 flex flex-wrap gap-1.5">
										{item.tags.map((tag) => <span class="text-xs text-30">#{tag}</span>)}
									</div>
								</div>
								<a href={item.url} target="_blank" rel="noopener noreferrer" class="clip-link inline-flex shrink-0 items-center justify-center gap-1 rounded-xl px-3 py-2 text-xs font-medium">
									查看原文
									<Icon is:inline name="material-symbols:arrow-outward-rounded" class="text-base" />
								</a>
							</div>
						</article>
					))}
				</div>
			</section>
		))}
	</div>
</MainGridLayout>

<style>
	.clip-heading-icon {
		background: linear-gradient(135deg, rgba(255, 196, 112, 0.24), rgba(241, 145, 184, 0.2));
		color: #d17858;
	}

	.clip-category-mark {
		width: 0.65rem;
		height: 0.65rem;
		border-radius: 0.2rem 0.2rem 0.45rem 0.2rem;
		background: linear-gradient(135deg, #f2b56b, #e58aa9);
		box-shadow: 0 0 0 5px rgba(242, 181, 107, 0.12);
	}

	.clip-scenario {
		background: linear-gradient(90deg, rgba(255, 196, 112, 0.1), rgba(241, 145, 184, 0.07));
		border: 1px solid rgba(226, 151, 92, 0.16);
	}

	.clip-link {
		border: 1px solid color-mix(in srgb, var(--primary) 24%, var(--line-divider));
		color: var(--primary);
		transition: background 160ms ease, color 160ms ease, transform 160ms ease;
	}

	.clip-link:hover {
		background: var(--primary);
		color: white;
		transform: translateY(-1px);
	}
</style>
