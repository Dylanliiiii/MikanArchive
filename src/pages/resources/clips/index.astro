---
import { Icon } from "astro-icon/components";
import ContentGridLayout from "@/layouts/ContentGridLayout.astro";
import { getMikanResourcesByKind, groupMikanResourcesByCategory } from "@/data/mikan";
import { url } from "@/utils/url-utils";
import "@/styles/resources.css";

const resources = getMikanResourcesByKind("clip");
const groups = groupMikanResourcesByCategory(resources);

function getClipsCategoryUrl(category: string) {
	return url(`/resources/clips/?category=${encodeURIComponent(category)}`);
}
---

<ContentGridLayout title="摘录收藏" description="为具体问题与知识点留下可回溯的网页线索" showCategoryBar={false}>
	<section data-clips-page class="resources-page card-base relative overflow-hidden px-5 py-7 sm:px-8 sm:py-9">
		<header class="tools-page-header relative z-10 mb-7">
			<div class="tools-eyebrow-row tools-eyebrow-row--clips">
				<Icon is:inline name="material-symbols:bookmarks-rounded" />
				<p class="tools-eyebrow">MIKAN CLIPPINGS</p>
			</div>
			<h1 class="tools-page-title">摘录收藏</h1>
			<p class="tools-page-description">记录某篇网页为什么有用，并一起保留来源、适用场景和收藏日期。</p>
		</header>

		{resources.length > 0 && (
			<nav class="tools-tab-wrapper clip-filter-pill relative z-10" aria-label="摘录分类">
				<div class="tools-tab-pill" data-clips-tab-nav>
					<div class="tools-tab-indicator" data-clips-tab-indicator></div>
					<a
						href={url("/resources/clips/")}
						data-clips-tab="all"
						class="tools-tab-btn tools-tab-btn-active"
						aria-current="page"
					>
						全部
						<span class="tools-tab-badge">{resources.length}</span>
					</a>
					{groups.map((group) => (
						<a
							href={getClipsCategoryUrl(group.category)}
							data-clips-tab={group.category}
							class="tools-tab-btn tools-tab-btn-inactive"
						>
							{group.category}
							<span class="tools-tab-badge">{group.count}</span>
						</a>
					))}
				</div>
			</nav>
		)}

		{resources.length > 0 ? (
			<div class="relative z-10">
				{groups.map((group) => (
					<section class="tools-category-group" data-clips-section={group.category}>
						<header class="tools-category-header">
							<div class="tools-category-name">
								<Icon is:inline name="material-symbols:label-outline-rounded" />
								<h2>{group.category}</h2>
							</div>
							<span class="tools-category-count">{group.count}</span>
							<span class="tools-category-line"></span>
						</header>

						<div class="clip-list">
							{group.items.map((item, index) => (
								<a
									href={item.url}
									target="_blank"
									rel="noopener noreferrer"
									class="clip-card group onload-animation"
									style={`animation-delay: calc(var(--content-delay) + ${index * 55}ms);`}
								>
									<div class="relative flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
										<div class="min-w-0 flex-1">
											<div class="flex flex-wrap items-center gap-2">
												{item.sourceName && <span class="clip-source-badge">{item.sourceName}</span>}
												{item.addedAt && <time datetime={item.addedAt} class="text-xs text-30">收藏于 {item.addedAt}</time>}
											</div>
											<h3 class="mt-2 text-lg font-bold text-90 transition-colors group-hover:text-(--primary)">{item.title}</h3>
											<p class="mt-2 text-sm leading-6 text-50">{item.note}</p>
											{item.scenario && (
												<div class="clip-scenario mt-3 flex items-start gap-2 rounded-xl px-3 py-2.5 text-sm leading-5 text-50">
													<Icon is:inline name="material-symbols:lightbulb-rounded" class="mt-0.5 shrink-0 text-lg text-[#d58a59]" />
													<span><strong class="font-semibold text-70">适用场景：</strong>{item.scenario}</span>
												</div>
											)}
											<div class="mt-3 flex flex-wrap gap-1.5">
												{item.tags.map((tag) => <span class="clip-tag">#{tag}</span>)}
											</div>
										</div>
										<span class="clip-link-hint inline-flex shrink-0 items-center justify-center gap-1 rounded-xl px-3 py-2 text-xs font-medium">
											查看原文
											<Icon is:inline name="material-symbols:arrow-outward-rounded" class="text-base" />
										</span>
									</div>
								</a>
							))}
						</div>
					</section>
				))}
			</div>
		) : (
			<div class="tools-empty relative z-10">
				<Icon is:inline name="material-symbols:bookmarks-outline-rounded" />
				<p>还没有配置摘录收藏。</p>
			</div>
		)}
	</section>

	<script is:inline>
		(function () {
			if (window.__mikanClipsReady) return;
			window.__mikanClipsReady = true;

			function getClipsRoot() {
				return document.querySelector("[data-clips-page]");
			}

			function updateClipsIndicator(targetLink) {
				if (!targetLink) return;
				var nav = targetLink.closest("[data-clips-tab-nav]");
				var indicator = nav && nav.querySelector("[data-clips-tab-indicator]");
				if (!indicator) return;

				indicator.style.left = targetLink.offsetLeft + "px";
				indicator.style.top = targetLink.offsetTop + "px";
				indicator.style.width = targetLink.offsetWidth + "px";
				indicator.style.height = targetLink.offsetHeight + "px";
				indicator.style.opacity = "1";
			}

			function getTabFromUrl() {
				var params = new URLSearchParams(window.location.search);
				return params.get("category") || "all";
			}

			function writeTabToUrl(targetTab) {
				var nextUrl = new URL(window.location.href);
				var params = new URLSearchParams(nextUrl.search);

				if (!targetTab || targetTab === "all") {
					params.delete("category");
				} else {
					params.set("category", targetTab);
				}

				nextUrl.search = params.toString();
				nextUrl.hash = "";
				history.pushState(null, "", nextUrl);
			}

			function activateClipsTab(targetTab, updateUrl) {
				var root = getClipsRoot();
				if (!root) return;

				var links = root.querySelectorAll("[data-clips-tab]");
				var sections = root.querySelectorAll("[data-clips-section]");
				var resolvedTab = targetTab || "all";
				var targetLink = null;

				links.forEach(function (link) {
					if (link.dataset.clipsTab === resolvedTab) targetLink = link;
				});

				if (!targetLink) {
					resolvedTab = "all";
					links.forEach(function (link) {
						if (link.dataset.clipsTab === "all") targetLink = link;
					});
				}

				root.setAttribute("data-clips-filtered", String(resolvedTab !== "all"));

				links.forEach(function (link) {
					var isActive = link === targetLink;
					link.classList.toggle("tools-tab-btn-active", isActive);
					link.classList.toggle("tools-tab-btn-inactive", !isActive);
					if (isActive) {
						link.setAttribute("aria-current", "page");
					} else {
						link.removeAttribute("aria-current");
					}
				});

				sections.forEach(function (section) {
					var isActive = resolvedTab === "all" || section.dataset.clipsSection === resolvedTab;
					section.classList.toggle("hidden", !isActive);
					if (isActive) {
						section.querySelectorAll(".clip-card").forEach(function (card) {
							card.style.animation = "none";
							void card.offsetHeight;
							card.style.animation = "";
						});
					}
				});

				requestAnimationFrame(function () {
					updateClipsIndicator(targetLink);
				});

				if (updateUrl) writeTabToUrl(resolvedTab);
			}

			function initClipsTabs() {
				activateClipsTab(getTabFromUrl(), false);
			}

			document.addEventListener("click", function (event) {
				var target = event.target instanceof Element ? event.target.closest("[data-clips-tab]") : null;
				if (!target) return;
				event.preventDefault();
				activateClipsTab(target.dataset.clipsTab || "all", true);
			});
			window.addEventListener("popstate", initClipsTabs);
			window.addEventListener("resize", function () {
				var activeLink = document.querySelector("[data-clips-page] .tools-tab-btn-active");
				if (activeLink) updateClipsIndicator(activeLink);
			});
			document.addEventListener("astro:page-load", initClipsTabs);
			document.addEventListener("swup:contentReplaced", initClipsTabs);
			initClipsTabs();
		})();
	</script>
</ContentGridLayout>
