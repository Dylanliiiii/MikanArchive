---
import { Icon } from "astro-icon/components";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import ContentGridLayout from "@/layouts/ContentGridLayout.astro";
import { getCategoryList } from "@/utils/content-utils";
import "@/styles/resources.css";

const categories = await getCategoryList();
const totalPosts = categories.reduce((sum, cat) => sum + cat.count, 0);
---

<ContentGridLayout title={i18n(I18nKey.categories)}>
    <section class="resources-page card-base relative overflow-hidden px-5 py-7 sm:px-8 sm:py-9">
        <header class="tools-page-header relative z-10 mb-7">
            <div class="tools-eyebrow-row">
                <Icon is:inline name="material-symbols:folder-open-rounded" />
                <p class="tools-eyebrow">MIKAN CATEGORIES</p>
            </div>
            <h1 class="tools-page-title">{i18n(I18nKey.categories)}</h1>
            <p class="tools-page-description">
                {i18n(I18nKey.allCategories)} · {totalPosts} {i18n(I18nKey.postsCount)}
            </p>
        </header>

    <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-4">
        {
            categories.map((category, index) => (
                <a
                    href={category.url}
                    class="card-base p-6 flex items-center gap-4 group onload-animation"
                    style={`animation-delay: calc(var(--content-delay) + ${index * 50}ms);`}
                >
                    <div class="shrink-0 w-14 h-14 rounded-full bg-(--primary)/10 group-hover:bg-(--primary)/20 flex items-center justify-center transition-colors">
                        <Icon is:inline
                            name="material-symbols:folder-open"
                            class="text-3xl text-(--primary)"
                        />
                    </div>
                    <div class="flex-1 min-w-0">
                        <h2 class="text-lg font-bold text-90 truncate group-hover:text-(--primary) transition-colors" title={category.name}>
                            {category.name}
                        </h2>
                        <p class="text-sm text-30 mt-1 group-hover:text-(--primary)/60 transition-colors">
                            {category.count} {i18n(I18nKey.postsCount)}
                        </p>
                    </div>
                    <div class="shrink-0">
                        <Icon is:inline
                            name="material-symbols:chevron-right-rounded"
                            class="text-2xl text-30 group-hover:text-(--primary) transition-colors "
                        />
                    </div>
                </a>
            ))
        }
    </div>

    <!-- 空状态 -->
    {
        categories.length === 0 && (
            <div class="relative z-10 rounded-2xl border border-(--line-divider) bg-black/[0.015] px-8 py-12 text-center dark:bg-white/[0.025]">
                <Icon is:inline
                    name="material-symbols:folder-off"
                    class="text-5xl text-30 mx-auto mb-4"
                />
                <p class="text-30">{i18n(I18nKey.noData)}</p>
            </div>
        )
    }
    </section>
</ContentGridLayout>
