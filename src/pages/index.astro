---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getMikanFriends, getMikanResources, getMikanTimeline, getMikanUpdates } from "@/data/mikan";
import { getSortedPostsList } from "@/utils/content-utils";
import { getPostUrlBySlug } from "@/utils/url-utils";

const posts = (await getSortedPostsList()).slice(0, 6);
const resources = getMikanResources();
const featuredResources = [
	...resources.filter((item) => item.featured),
	...resources.filter((item) => !item.featured),
].slice(0, 4);
const friends = getMikanFriends().slice(0, 4);
const timeline = getMikanTimeline().slice(0, 4);
const updates = getMikanUpdates().slice(0, 4);
---

<MainGridLayout title="主页" description="MikanArchive 知识收藏馆">
	<section class="card-base p-6 md:p-8 mb-4">
		<div class="flex items-center gap-3 mb-5">
			<div class="h-10 w-10 rounded-xl bg-(--primary) text-white dark:text-black/70 flex items-center justify-center">
				<Icon is:inline name="material-symbols:auto-stories-rounded" class="text-2xl" />
			</div>
			<div>
				<h2 class="text-2xl font-bold text-90">最近整理</h2>
				<p class="text-sm text-30 mt-1">教程、笔记和问题解决记录。</p>
			</div>
		</div>
		<div class="grid gap-3">
			{posts.map((post) => (
				<a href={getPostUrlBySlug(post.id)} class="group rounded-2xl border border-(--line-divider) p-4 hover:border-(--primary) hover:bg-(--btn-card-bg-hover) transition-all">
					<div class="flex items-start justify-between gap-4">
						<div class="min-w-0">
							<h3 class="font-bold text-lg text-90 group-hover:text-(--primary) transition-colors truncate">{post.data.title}</h3>
							<p class="text-sm text-50 mt-1 line-clamp-2">{post.data.description}</p>
							<div class="mt-3 flex flex-wrap gap-1.5">
								{post.data.tags.slice(0, 4).map((tag) => <span class="text-[0.7rem] rounded-md bg-black/5 dark:bg-white/10 px-2 py-1 text-50">#{tag}</span>)}
							</div>
						</div>
						<Icon is:inline name="material-symbols:arrow-forward-rounded" class="text-2xl text-(--primary) shrink-0 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all" />
					</div>
				</a>
			))}
		</div>
	</section>

	<div class="grid gap-4 lg:grid-cols-2">
		<section class="card-base p-6">
			<div class="mb-4 flex items-center justify-between gap-3">
				<h2 class="text-xl font-bold text-90">精选收藏</h2>
				<a class="text-sm text-(--primary) font-medium" href="/resources/">全部</a>
			</div>
			<div class="grid gap-3">
				{featuredResources.map((item) => (
					<a href={item.url} target="_blank" rel="noopener noreferrer" class="rounded-xl border border-(--line-divider) p-4 hover:border-(--primary) transition-colors">
						<div class="font-bold text-90">{item.title}</div>
						<p class="mt-1 text-sm text-50 line-clamp-2">{item.note}</p>
					</a>
				))}
			</div>
		</section>

		<section class="card-base p-6">
			<div class="mb-4 flex items-center justify-between gap-3">
				<h2 class="text-xl font-bold text-90">足迹</h2>
				<a class="text-sm text-(--primary) font-medium" href="/records/">查看</a>
			</div>
			<div class="space-y-3">
				{[...updates, ...timeline].slice(0, 4).map((item) => (
					<div class="rounded-xl bg-black/5 dark:bg-white/8 px-4 py-3">
						<div class="text-xs text-30">{item.date}</div>
						<div class="mt-1 font-semibold text-90">{item.title}</div>
					</div>
				))}
			</div>
		</section>
	</div>

	<section class="card-base p-6 mt-4">
		<div class="mb-4 flex items-center justify-between gap-3">
			<h2 class="text-xl font-bold text-90">友链一角</h2>
			<a class="text-sm text-(--primary) font-medium" href="/friends/">联系我</a>
		</div>
		<div class="grid gap-3 md:grid-cols-2">
			{friends.map((friend) => (
				<a href={friend.url} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 rounded-xl border border-(--line-divider) p-3 hover:border-(--primary) transition-colors">
					<img src={friend.avatar} alt={friend.name} class="h-12 w-12 rounded-xl object-cover bg-black/5 dark:bg-white/10" />
					<div class="min-w-0">
						<div class="font-bold text-90 group-hover:text-(--primary) truncate">{friend.name}</div>
						<div class="text-sm text-50 truncate">{friend.description}</div>
					</div>
				</a>
			))}
		</div>
	</section>
</MainGridLayout>
