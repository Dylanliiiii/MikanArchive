		.home-orbit-center {
			top: 4.6rem;
			width: 7rem;
			height: 7rem;
		}

		.home-visit-capsule {
			position: relative;
			left: auto;
			bottom: auto;
			width: 100%;
			margin-top: 1rem;
			transform: none;
		}
	}

	@media (max-width: 640px) {
		.home-title-mask h2 {
			font-size: 3.8rem;
