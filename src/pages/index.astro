</style>

<script is:inline>
	function initMikanHome() {
		const root = document.getElementById("mikan-home-page");
		if (!root) return;

		document.body.dataset.contentOnly = "true";
		document.body.classList.remove("enable-banner", "is-home", "lg:is-home");
		document.body.classList.add("no-banner-layout");

		const revealItems = [...root.querySelectorAll("[data-home-reveal]")];
		revealItems.forEach((item) => {
			const isHeroContent = item.closest(".home-hero");
			if (!item.classList.contains("is-visible")) {
				item.classList.add("home-reveal-pending");
			}
			if (isHeroContent) {
				item.dataset.revealImmediate = "true";
			}
		});
		if ("IntersectionObserver" in window) {
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (!entry.isIntersecting) return;
						entry.target.classList.remove("home-reveal-pending");
						entry.target.classList.add("is-visible");
						observer.unobserve(entry.target);
					});
				},
				{ rootMargin: "0px 0px -28% 0px", threshold: 0.24 },
			);
			revealItems.forEach((item) => observer.observe(item));
		} else {
			revealItems.forEach((item) => {
				item.classList.remove("home-reveal-pending");
				item.classList.add("is-visible");
			});
		}

		requestAnimationFrame(() => {
			revealItems.forEach((item) => {
				if (item.dataset.revealImmediate !== "true") return;
				const rect = item.getBoundingClientRect();
				if (rect.top < window.innerHeight * 0.94 && rect.bottom > 0) {
					item.classList.remove("home-reveal-pending");
					item.classList.add("is-visible");
				}
			});
		});

		const parallaxItems = [...root.querySelectorAll("[data-home-parallax]")];
		function revealItemsInViewport() {
			const viewportHeight = Math.max(1, window.innerHeight);
			revealItems.forEach((item) => {
				if (item.classList.contains("is-visible")) return;
				const isImmediate = item.dataset.revealImmediate === "true";
				const rect = item.getBoundingClientRect();
				const triggerLine = viewportHeight * (isImmediate ? 0.94 : 0.76);
				if (rect.top < triggerLine && rect.bottom > viewportHeight * 0.06) {
					item.classList.remove("home-reveal-pending");
					item.classList.add("is-visible");
				}
			});
		}

		window.__mikanHomeScrollState = {
			root,
			parallaxItems,
			ticking: false,
		};
		function updateHomeScroll() {
			const state = window.__mikanHomeScrollState;
			if (!state?.root) return;
			const scrollTop = window.scrollY || document.documentElement.scrollTop || 0;
			const viewport = Math.max(1, window.innerHeight);
			const progress = Math.min(1, Math.max(0, scrollTop / viewport));
			state.root.style.setProperty("--home-scroll", progress.toFixed(3));
			state.parallaxItems.forEach((item) => {
				item.style.setProperty("--home-scroll", progress.toFixed(3));
			});
			revealItemsInViewport();
			state.ticking = false;
		}

		function requestHomeScrollFrame() {
			const state = window.__mikanHomeScrollState;
			if (!state || state.ticking) return;
			state.ticking = true;
			requestAnimationFrame(updateHomeScroll);
		}

		if (!window.__mikanHomeScrollBound) {
			window.__mikanHomeScrollBound = true;
			window.addEventListener("scroll", requestHomeScrollFrame, { passive: true });
			window.addEventListener("resize", requestHomeScrollFrame);
		}

		requestHomeScrollFrame();
		revealItemsInViewport();
	}

	initMikanHome();
	document.addEventListener("DOMContentLoaded", initMikanHome);
	document.addEventListener("astro:page-load", initMikanHome);
	document.addEventListener("swup:contentReplaced", initMikanHome);
</script>
