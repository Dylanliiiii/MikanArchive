---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getMikanArchiveGroups, getMikanFriends, getMikanResources, getMikanUpdates } from "@/data/mikan";
import { getSortedPostsList, getTagList } from "@/utils/content-utils";

const posts = await getSortedPostsList();
const tags = await getTagList();
const resources = getMikanResources();
const friends = getMikanFriends();
const archiveGroups = getMikanArchiveGroups();
const updates = getMikanUpdates();
const stats = [
	{ label: "文章", value: posts.length, icon: "material-symbols:article-rounded", tone: "stat-card--blue" },
	{ label: "标签", value: tags.length, icon: "material-symbols:tag-rounded", tone: "stat-card--mint" },
	{ label: "收藏", value: resources.length, icon: "material-symbols:bookmark-heart-rounded", tone: "stat-card--pink" },
	{ label: "友邻", value: friends.length, icon: "material-symbols:group-rounded", tone: "stat-card--yellow" },
];
---

<MainGridLayout title="足迹" description="写作、收藏和站点维护记录">
	<section class="grid gap-3 sm:grid-cols-2 md:grid-cols-4 mb-4">
		{stats.map((item) => (
			<div class:list={["card-base stat-card p-5", item.tone]}>
				<div class="stat-card__icon flex h-10 w-10 items-center justify-center rounded-xl">
					<Icon is:inline name={item.icon} class="text-xl" />
				</div>
				<div class="mt-3 text-2xl font-bold text-90">{item.value}</div>
				<div class="text-sm text-30">{item.label}</div>
			</div>
		))}
	</section>

	<section class="card-base p-5 sm:p-6 mb-4">
		<div class="mb-5 flex items-center gap-3">
			<div class="h-9 w-9 rounded-xl bg-(--primary) text-white dark:text-black/70 flex items-center justify-center">
				<Icon is:inline name="material-symbols:update-rounded" class="text-2xl" />
			</div>
			<div>
				<h1 class="text-2xl font-bold text-90">最近更新</h1>
				<p class="text-sm text-30 mt-1">站点、文章和收藏的近期变化。</p>
			</div>
		</div>
		<div class="grid gap-3 md:grid-cols-2">
			{updates.map((item) => (
				<div class="rounded-xl border border-(--line-divider) bg-black/[0.015] p-4 dark:bg-white/[0.025]">
					<div class="flex flex-wrap items-center gap-2">
						<span class="text-xs text-30">{item.date}</span>
						<span class="rounded-md bg-(--primary)/10 px-2 py-0.5 text-xs text-(--primary)">{item.type}</span>
					</div>
					<div class="mt-2 font-bold text-90">{item.title}</div>
					{item.description && <p class="mt-1 text-sm leading-6 text-50">{item.description}</p>}
				</div>
			))}
		</div>
	</section>

	<section class="card-base archive-card p-5 sm:p-6">
		<div class="mb-7 flex items-start gap-3">
			<div class="h-9 w-9 shrink-0 rounded-xl bg-(--primary)/12 text-(--primary) flex items-center justify-center">
				<Icon is:inline name="material-symbols:account-tree-rounded" class="text-2xl" />
			</div>
			<div>
				<h2 class="text-xl font-bold text-90">足迹归档</h2>
				<p class="mt-1 text-sm leading-6 text-30">从年份沿主干展开月份与记录。将鼠标移到分支上，或用键盘聚焦，就能看清当前路径。</p>
			</div>
		</div>

		<div class="archive-tree">
			<div class="archive-trunk" aria-hidden="true"></div>
			{archiveGroups.map((yearGroup) => (
				<section class="archive-year">
					<div class="archive-year-branch" aria-hidden="true"></div>
					<div class="archive-year-node" aria-hidden="true"></div>
					<div class="archive-year-heading">
						<h3 class="text-xl font-bold text-90">{yearGroup.year}</h3>
						<span class="rounded-full bg-(--primary)/10 px-2.5 py-1 text-xs text-(--primary)">{yearGroup.count} 条记录</span>
					</div>

					<div class="archive-months">
						{yearGroup.months.map((monthGroup) => (
							<section class="archive-month" tabindex="0">
								<div class="archive-month-branch" aria-hidden="true"></div>
								<div class="archive-month-node" aria-hidden="true"></div>
								<div class="archive-month-heading">
									<h4 class="font-bold text-70">{monthGroup.label}</h4>
									<span class="text-xs text-30">{monthGroup.count} 条</span>
								</div>

								<div class="archive-records">
									{monthGroup.items.map((item) => (
										<article class="archive-record" tabindex="0">
											<div class="archive-record-branch" aria-hidden="true"></div>
											<div class="archive-record-node" aria-hidden="true"></div>
											<div class="archive-record-card rounded-2xl border border-(--line-divider) p-4">
												<div class="flex flex-wrap items-center gap-2">
													<time datetime={item.date} class="text-xs text-30">{item.date}</time>
													{item.category && <span class="rounded-md bg-black/5 px-2 py-0.5 text-[0.68rem] text-50 dark:bg-white/10">{item.category}</span>}
												</div>
												<div class="mt-1.5 font-bold text-90">{item.title}</div>
												<p class="mt-1 text-sm leading-6 text-50">{item.description}</p>
											</div>
										</article>
									))}
								</div>
							</section>
						))}
					</div>
				</section>
			))}
		</div>
	</section>
</MainGridLayout>

<style>
	.stat-card {
		position: relative;
		overflow: hidden;
	}

	.stat-card::after {
		content: "";
		position: absolute;
		width: 5rem;
		height: 5rem;
		right: -2rem;
		top: -2rem;
		border-radius: 999px;
		background: currentColor;
		opacity: 0.06;
	}

	.stat-card__icon { background: currentColor; }
	.stat-card__icon :global(svg) { color: white; }
	.stat-card--blue { color: #719ce8; }
	.stat-card--mint { color: #58bba2; }
	.stat-card--pink { color: #df86a9; }
	.stat-card--yellow { color: #d9a653; }

	.archive-tree {
		--tree-offset: 3.75rem;
		position: relative;
		padding-left: var(--tree-offset);
	}

	.archive-trunk {
		position: absolute;
		left: 1rem;
		top: 0.9rem;
		bottom: 1rem;
		width: 2px;
		border-radius: 999px;
		background: linear-gradient(to bottom, var(--primary), color-mix(in srgb, var(--primary) 25%, var(--line-divider)));
		opacity: 0.72;
	}

	.archive-year {
		position: relative;
		padding-bottom: 2.25rem;
	}

	.archive-year:last-child { padding-bottom: 0; }

	.archive-year-branch {
		position: absolute;
		left: calc(-1 * (var(--tree-offset) - 1rem));
		top: 1rem;
		width: calc(var(--tree-offset) - 1rem);
		border-top: 2px solid color-mix(in srgb, var(--primary) 58%, var(--line-divider));
	}

	.archive-year-node {
		position: absolute;
		left: calc(-1 * (var(--tree-offset) - 0.62rem));
		top: 0.65rem;
		width: 0.75rem;
		height: 0.75rem;
		border-radius: 999px;
		background: var(--primary);
		box-shadow: 0 0 0 5px color-mix(in srgb, var(--primary) 13%, transparent);
	}

	.archive-year-heading,
	.archive-month-heading {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.archive-months {
		position: relative;
		margin-top: 1.25rem;
	}

	.archive-months::before {
		content: "";
		position: absolute;
		left: 0.42rem;
		top: -0.75rem;
		bottom: 1.2rem;
		border-left: 1px dashed var(--line-divider);
	}

	.archive-month {
		position: relative;
		padding: 0.35rem 0 1.5rem 2.25rem;
		outline: none;
	}

	.archive-month:last-child { padding-bottom: 0; }

	.archive-month-branch {
		position: absolute;
		left: 0.42rem;
		top: 1rem;
		width: 1.83rem;
		border-top: 1px dashed var(--line-divider);
		transition: border-color 160ms ease, border-style 160ms ease, border-width 160ms ease;
	}

	.archive-month-node {
		position: absolute;
		left: 0.18rem;
		top: 0.76rem;
		width: 0.52rem;
		height: 0.52rem;
		border-radius: 999px;
		border: 2px solid var(--line-divider);
		background: var(--card-bg);
		transition: border-color 160ms ease, background 160ms ease;
	}

	.archive-records {
		position: relative;
		margin-top: 0.75rem;
	}

	.archive-records::before {
		content: "";
		position: absolute;
		left: 0.48rem;
		top: -0.45rem;
		bottom: 1.25rem;
		border-left: 1px dashed var(--line-divider);
	}

	.archive-record {
		position: relative;
		padding: 0 0 0.9rem 1.75rem;
		outline: none;
	}

	.archive-record:last-child { padding-bottom: 0; }

	.archive-record-branch {
		position: absolute;
		left: 0.48rem;
		top: 1.15rem;
		width: 1.27rem;
		border-top: 1px dashed var(--line-divider);
		transition: border-color 160ms ease, border-style 160ms ease, border-width 160ms ease;
	}

	.archive-record-node {
		position: absolute;
		left: 0.29rem;
		top: 0.97rem;
		width: 0.38rem;
		height: 0.38rem;
		border-radius: 999px;
		background: var(--line-divider);
		transition: background 160ms ease, box-shadow 160ms ease;
	}

	.archive-record-card {
		background: color-mix(in srgb, var(--card-bg) 88%, transparent);
		transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
	}

	.archive-month:hover > .archive-month-branch,
	.archive-month:focus > .archive-month-branch,
	.archive-month:focus-within > .archive-month-branch,
	.archive-record:hover > .archive-record-branch,
	.archive-record:focus > .archive-record-branch {
		border-top-style: solid;
		border-top-width: 2px;
		border-color: var(--primary);
	}

	.archive-month:hover > .archive-month-node,
	.archive-month:focus > .archive-month-node,
	.archive-month:focus-within > .archive-month-node {
		border-color: var(--primary);
		background: var(--primary);
	}

	.archive-record:hover > .archive-record-node,
	.archive-record:focus > .archive-record-node {
		background: var(--primary);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--primary) 12%, transparent);
	}

	.archive-record:hover > .archive-record-card,
	.archive-record:focus > .archive-record-card {
		transform: translateX(2px);
		border-color: color-mix(in srgb, var(--primary) 36%, transparent);
		box-shadow: 0 10px 24px color-mix(in srgb, var(--primary) 8%, transparent);
	}

	@media (max-width: 640px) {
		.archive-tree { --tree-offset: 2.35rem; }
		.archive-month { padding-left: 1.6rem; }
		.archive-month-branch { width: 1.18rem; }
		.archive-record { padding-left: 1.3rem; }
		.archive-record-branch { width: 0.82rem; }
		.archive-record-card { padding: 0.85rem; }
	}
</style>
