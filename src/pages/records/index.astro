---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getMikanResources, getMikanTimeline, getMikanUpdates, getMikanFriends } from "@/data/mikan";
import { getSortedPostsList, getTagList } from "@/utils/content-utils";

const posts = await getSortedPostsList();
const tags = await getTagList();
const resources = getMikanResources();
const friends = getMikanFriends();
const timeline = getMikanTimeline();
const updates = getMikanUpdates();
const stats = [
	{ label: "文章", value: posts.length, icon: "material-symbols:article-rounded" },
	{ label: "标签", value: tags.length, icon: "material-symbols:tag-rounded" },
	{ label: "收藏", value: resources.length, icon: "material-symbols:bookmark-heart-rounded" },
	{ label: "友邻", value: friends.length, icon: "material-symbols:group-rounded" },
];
---

<MainGridLayout title="足迹" description="写作、收藏和站点维护记录">
	<section class="grid gap-4 md:grid-cols-4 mb-4">
		{stats.map((item) => (
			<div class="card-base p-5">
				<Icon is:inline name={item.icon} class="text-2xl text-(--primary)" />
				<div class="mt-3 text-2xl font-bold text-90">{item.value}</div>
				<div class="text-sm text-30">{item.label}</div>
			</div>
		))}
	</section>

	<section class="card-base p-6 mb-4">
		<div class="mb-5 flex items-center gap-3">
			<div class="h-9 w-9 rounded-xl bg-(--primary) text-white dark:text-black/70 flex items-center justify-center">
				<Icon is:inline name="material-symbols:update-rounded" class="text-2xl" />
			</div>
			<div>
				<h1 class="text-2xl font-bold text-90">最近更新</h1>
				<p class="text-sm text-30 mt-1">站点、文章和收藏的近期变化。</p>
			</div>
		</div>
		<div class="grid gap-3">
			{updates.map((item) => (
				<div class="rounded-xl border border-(--line-divider) p-4">
					<div class="flex flex-wrap items-center gap-2">
						<span class="text-xs text-30">{item.date}</span>
						<span class="rounded-md bg-(--primary)/10 px-2 py-0.5 text-xs text-(--primary)">{item.type}</span>
					</div>
					<div class="mt-2 font-bold text-90">{item.title}</div>
					{item.description && <p class="mt-1 text-sm text-50">{item.description}</p>}
				</div>
			))}
		</div>
	</section>

	<section class="card-base p-6">
		<h2 class="mb-5 text-xl font-bold text-90">时间线</h2>
		<div class="relative pl-5">
			<div class="absolute left-1.5 top-1 bottom-1 w-px bg-(--line-divider)"></div>
			{timeline.map((item) => (
				<div class="relative mb-5 last:mb-0">
					<div class="absolute -left-5 top-1.5 h-3 w-3 rounded-full bg-(--primary) ring-4 ring-(--card-bg)"></div>
					<div class="text-xs text-30">{item.date}</div>
					<div class="mt-1 font-bold text-90">{item.title}</div>
					<p class="mt-1 text-sm leading-6 text-50">{item.description}</p>
				</div>
			))}
		</div>
	</section>
</MainGridLayout>
