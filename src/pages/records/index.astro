---
import { CalendarWidget } from "@/components/widgets/CalendarWidget";
import { WritingHeatmap } from "@/components/widgets/WritingHeatmap";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getFriends, getResources, getTimeline, getUpdates, sortPosts } from "../_data";

const rawPosts = await getCollection("posts");
const posts = sortPosts(rawPosts);
const resources = await getResources();
const friends = await getFriends();
const timeline = await getTimeline();
const updates = await getUpdates();
const heatmapItems = posts.map((post) => ({ date: new Date(post.data.published).toISOString().slice(0, 10), count: 1 }));
---

<BaseLayout title="足迹" description="记录日历、写作热力图和更新轨迹">
  <section class="container page-shell">
    <div class="section-title">
      <div>
        <h1 class="text-3xl font-black tracking-normal sm:text-4xl">足迹</h1>
        <p>记录写作、收藏和站点维护留下来的时间纹理。</p>
      </div>
    </div>

    <div class="mb-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="surface p-4"><p class="text-2xl font-bold">{posts.length}</p><p class="mt-1 text-sm text-foreground/60">文章</p></div>
      <div class="surface p-4"><p class="text-2xl font-bold">{resources.length}</p><p class="mt-1 text-sm text-foreground/60">收藏</p></div>
      <div class="surface p-4"><p class="text-2xl font-bold">{friends.length}</p><p class="mt-1 text-sm text-foreground/60">友邻</p></div>
      <div class="surface p-4"><p class="text-2xl font-bold">{updates.length}</p><p class="mt-1 text-sm text-foreground/60">更新</p></div>
    </div>

    <div class="grid gap-4 lg:grid-cols-2">
      <CalendarWidget client:load events={timeline} />
      <WritingHeatmap client:load items={heatmapItems} />
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <section class="surface p-5">
        <h2 class="text-xl font-bold">时间线</h2>
        <div class="mt-5 space-y-5">
          {
            timeline.map((item) => (
              <article class="border-l-2 border-primary/25 pl-4">
                <time class="text-xs text-foreground/50" datetime={item.date}>{item.date}</time>
                <h3 class="mt-1 font-bold">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-foreground/60">{item.description}</p>
              </article>
            ))
          }
        </div>
      </section>
      <section class="surface p-5">
        <h2 class="text-xl font-bold">最近更新</h2>
        <div class="mt-5 space-y-4">
          {
            updates.map((item) => (
              <article class="rounded-lg border border-border/70 bg-white/60 p-4">
                <div class="flex flex-wrap items-center gap-2">
                  <time class="badge" datetime={item.date}>{item.date}</time>
                  <span class="badge bg-accent/25 text-emerald-800">{item.type}</span>
                </div>
                <h3 class="mt-3 font-bold">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-foreground/60">{item.description}</p>
              </article>
            ))
          }
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
