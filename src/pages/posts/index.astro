---
import PostPage from "@/components/layout/PostPage.astro";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getSortedPosts } from "@/utils/content-utils";

const posts = await getSortedPosts();
const page = {
	data: posts,
	currentPage: 1,
	lastPage: 1,
	size: posts.length,
	total: posts.length,
	url: {
		current: "/posts/",
		next: undefined,
		prev: undefined,
		first: "/posts/",
		last: "/posts/",
	},
	start: 0,
	end: posts.length - 1,
};
---

<MainGridLayout title="文库" description="文章、教程和笔记列表">
  <PostPage page={page} />
</MainGridLayout>
