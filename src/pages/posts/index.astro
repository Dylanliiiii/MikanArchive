---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import ContentGridLayout from "@/layouts/ContentGridLayout.astro";
import { getSortedPosts } from "@/utils/content-utils";
import { formatDateToYYYYMMDD } from "@/utils/date-utils";
import { getPostUrlBySlug } from "@/utils/url-utils";
import "@/styles/resources.css";

const posts = await getSortedPosts();
type PostEntry = CollectionEntry<"posts">;

type PostTagGroup = {
	tag: string;
	count: number;
	posts: PostEntry[];
};

function normalizePostTag(tag: string) {
	return tag.trim();
}

function groupPostsByTag(postList: PostEntry[]): PostTagGroup[] {
	const groups = new Map<string, PostEntry[]>();

	for (const post of postList) {
		const tags = (post.data.tags ?? []).map(normalizePostTag).filter(Boolean);
		const targetTags = tags.length > 0 ? tags : ["未标签"];
		const seenTags = new Set<string>();

		for (const tag of targetTags) {
			if (seenTags.has(tag)) continue;
			seenTags.add(tag);
			groups.set(tag, [...(groups.get(tag) ?? []), post]);
		}
	}

	return [...groups]
		.map(([tag, items]) => ({ tag, count: items.length, posts: items }))
		.sort(
			(a, b) =>
				b.count - a.count || a.tag.localeCompare(b.tag, "zh-CN"),
		);
}

const groups = groupPostsByTag(posts);
---

<ContentGridLayout title="文章" description="文章、教程和笔记列表">
  <section class="resources-page card-base article-page relative overflow-hidden px-5 py-7 sm:px-8 sm:py-9">
    <header class="tools-page-header relative z-10 mb-7">
      <div class="tools-eyebrow-row">
        <Icon is:inline name="material-symbols:article-rounded" />
        <p class="tools-eyebrow">MIKAN ARTICLES</p>
      </div>
      <h1 class="tools-page-title">文章</h1>
      <p class="tools-page-description">文章、教程和笔记列表。分类标签就是文章分类，把同类型内容收在同一个小标题下。</p>
    </header>

    {posts.length > 0 && (
      <nav class="tools-tab-wrapper relative z-10" aria-label="文章分类标签">
        <div class="tools-tab-pill" data-post-tag-nav>
          <div class="tools-tab-indicator" data-post-tag-indicator></div>
          <button
            type="button"
            data-post-tag="all"
            class="tools-tab-btn tools-tab-btn-active"
            aria-pressed="true"
            disabled
          >
            全部
            <span class="tools-tab-badge">{posts.length}</span>
          </button>
          {groups.map((group) => (
            <button
              type="button"
              data-post-tag={group.tag}
              class="tools-tab-btn tools-tab-btn-inactive"
              aria-pressed="false"
            >
              {group.tag}
              <span class="tools-tab-badge">{group.count}</span>
            </button>
          ))}
        </div>
      </nav>
    )}

    {posts.length > 0 ? (
      <div class="relative z-10">
        <div data-post-tag-section="all">
          {groups.map((group) => (
            <section class="tools-category-group article-tag-group">
              <header class="tools-category-header">
                <div class="tools-category-name">
                  <Icon is:inline name="material-symbols:label-outline-rounded" />
                  <h2>{group.tag}</h2>
                </div>
                <span class="tools-category-count">{group.count}</span>
                <span class="tools-category-line"></span>
              </header>
              <div class="article-card-list">
                {group.posts.map((entry, index) => (
                  <a
                    href={getPostUrlBySlug(entry.id)}
                    aria-label={`打开文章：${entry.data.title}`}
                    class="article-strip-card group onload-animation"
                    style={`animation-delay: calc(var(--content-delay) + ${index * 50}ms);`}
                  >
                    <div class="article-strip-main">
                      <div class="article-strip-heading">
                        <h3 class="article-strip-title">
                          {entry.data.title}
                          {entry.data.password && (
                            <Icon is:inline name="material-symbols:lock-outline" />
                          )}
                        </h3>
                        <div class="article-strip-badges">
                          {entry.data.pinned && <span>置顶</span>}
                          {entry.data.draft && <span>草稿</span>}
                        </div>
                      </div>

                      <div class="article-strip-meta">
                        <span>
                          <Icon is:inline name="material-symbols:calendar-today-outline-rounded" />
                          {formatDateToYYYYMMDD(entry.data.published)}
                        </span>
                        {entry.data.updated && entry.data.updated.getTime() !== entry.data.published.getTime() && (
                          <span>
                            <Icon is:inline name="material-symbols:edit-calendar-outline-rounded" />
                            {formatDateToYYYYMMDD(entry.data.updated)}
                          </span>
                        )}
                        {entry.data.category && (
                          <span>
                            <Icon is:inline name="material-symbols:book-2-outline-rounded" />
                            {entry.data.category}
                          </span>
                        )}
                      </div>

                      {entry.data.description && (
                        <p class="article-strip-description">{entry.data.description}</p>
                      )}

                      <div class="article-strip-tags" aria-label="文章标签">
                        {entry.data.tags.length > 0 ? (
                          entry.data.tags.map((tag) => <span>#{tag.trim()}</span>)
                        ) : (
                          <span>#未标签</span>
                        )}
                      </div>
                    </div>
                    <span class="article-strip-enter" aria-hidden="true">
                      <Icon is:inline name="material-symbols:arrow-forward-rounded" />
                    </span>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>

        {groups.map((group) => (
          <div data-post-tag-section={group.tag} class="hidden">
            <section class="tools-category-group article-tag-group">
              <header class="tools-category-header">
                <div class="tools-category-name">
                  <Icon is:inline name="material-symbols:label-outline-rounded" />
                  <h2>{group.tag}</h2>
                </div>
                <span class="tools-category-count">{group.count}</span>
                <span class="tools-category-line"></span>
              </header>
              <div class="article-card-list">
                {group.posts.map((entry, index) => (
                  <a
                    href={getPostUrlBySlug(entry.id)}
                    aria-label={`打开文章：${entry.data.title}`}
                    class="article-strip-card group onload-animation"
                    style={`animation-delay: calc(var(--content-delay) + ${index * 50}ms);`}
                  >
                    <div class="article-strip-main">
                      <div class="article-strip-heading">
                        <h3 class="article-strip-title">
                          {entry.data.title}
                          {entry.data.password && (
                            <Icon is:inline name="material-symbols:lock-outline" />
                          )}
                        </h3>
                        <div class="article-strip-badges">
                          {entry.data.pinned && <span>置顶</span>}
                          {entry.data.draft && <span>草稿</span>}
                        </div>
                      </div>

                      <div class="article-strip-meta">
                        <span>
                          <Icon is:inline name="material-symbols:calendar-today-outline-rounded" />
                          {formatDateToYYYYMMDD(entry.data.published)}
                        </span>
                        {entry.data.updated && entry.data.updated.getTime() !== entry.data.published.getTime() && (
                          <span>
                            <Icon is:inline name="material-symbols:edit-calendar-outline-rounded" />
                            {formatDateToYYYYMMDD(entry.data.updated)}
                          </span>
                        )}
                        {entry.data.category && (
                          <span>
                            <Icon is:inline name="material-symbols:book-2-outline-rounded" />
                            {entry.data.category}
                          </span>
                        )}
                      </div>

                      {entry.data.description && (
                        <p class="article-strip-description">{entry.data.description}</p>
                      )}

                      <div class="article-strip-tags" aria-label="文章标签">
                        {entry.data.tags.length > 0 ? (
                          entry.data.tags.map((tag) => <span>#{tag.trim()}</span>)
                        ) : (
                          <span>#未标签</span>
                        )}
                      </div>
                    </div>
                    <span class="article-strip-enter" aria-hidden="true">
                      <Icon is:inline name="material-symbols:arrow-forward-rounded" />
                    </span>
                  </a>
                ))}
              </div>
            </section>
          </div>
        ))}
      </div>
    ) : (
      <div class="tools-empty relative z-10">
        <Icon is:inline name="material-symbols:article-outline-rounded" />
        <p>还没有公开文章。</p>
      </div>
    )}
  </section>

  <script is:inline>
    (function () {
      if (window.__mikanPostTagsReady) return;
      window.__mikanPostTagsReady = true;

      function getPostTagRoot() {
        return document.querySelector(".article-page");
      }

      function updateIndicator(targetButton) {
        if (!targetButton) return;
        var nav = targetButton.closest("[data-post-tag-nav]");
        var indicator = nav && nav.querySelector("[data-post-tag-indicator]");
        if (!indicator) return;

        indicator.style.left = targetButton.offsetLeft + "px";
        indicator.style.top = targetButton.offsetTop + "px";
        indicator.style.width = targetButton.offsetWidth + "px";
        indicator.style.height = targetButton.offsetHeight + "px";
        indicator.style.opacity = "1";
      }

      function activatePostTag(targetTag, updateHash) {
        var root = getPostTagRoot();
        if (!root || !targetTag) return;

        var buttons = root.querySelectorAll("[data-post-tag]");
        var sections = root.querySelectorAll("[data-post-tag-section]");
        var targetButton = null;

        buttons.forEach(function (button) {
          if (button.dataset.postTag === targetTag) targetButton = button;
        });
        if (!targetButton) return;

        buttons.forEach(function (button) {
          var isActive = button === targetButton;
          button.classList.toggle("tools-tab-btn-active", isActive);
          button.classList.toggle("tools-tab-btn-inactive", !isActive);
          button.setAttribute("aria-pressed", String(isActive));
          button.disabled = isActive;
        });

        sections.forEach(function (section) {
          var isActive = section.dataset.postTagSection === targetTag;
          section.classList.toggle("hidden", !isActive);
        });

        requestAnimationFrame(function () { updateIndicator(targetButton); });
        if (updateHash !== false) {
          var nextHash = "#posts-" + encodeURIComponent(targetTag);
          if (window.location.hash !== nextHash) history.replaceState(null, "", nextHash);
        }
      }

      function initPostTags() {
        var targetTag = "all";
        if (window.location.hash.indexOf("#posts-") === 0) {
          try {
            targetTag = decodeURIComponent(window.location.hash.slice(7));
          } catch (_) {
            targetTag = "all";
          }
        }
        activatePostTag(targetTag, false);
      }

      document.addEventListener("click", function (event) {
        var target = event.target instanceof Element ? event.target.closest("[data-post-tag]") : null;
        if (target) activatePostTag(target.dataset.postTag, true);
      });
      window.addEventListener("hashchange", initPostTags);
      window.addEventListener("resize", function () {
        var activeButton = document.querySelector(".article-page .tools-tab-btn-active");
        if (activeButton) updateIndicator(activeButton);
      });
      document.addEventListener("astro:page-load", initPostTags);
      document.addEventListener("swup:contentReplaced", initPostTags);
      initPostTags();
    })();
  </script>
</ContentGridLayout>
