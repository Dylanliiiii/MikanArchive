---
import FriendCard from "@/components/cards/FriendCard.astro";
import { FriendApplyDialog } from "@/components/dialogs/FriendApplyDialog";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getFriends, getSites } from "../_data";

const friends = await getFriends();
const sites = await getSites();
const categories = [...new Set(friends.map((friend) => friend.category))];
---

<BaseLayout title="友邻" description="友链名片墙和申请入口">
  <section class="container page-shell">
    <div class="section-title">
      <div>
        <h1 class="text-3xl font-black tracking-normal sm:text-4xl">友邻</h1>
        <p>把仍然愿意认真写东西、认真收藏链接的站点摆在一起。</p>
      </div>
      <FriendApplyDialog client:load />
    </div>

    <div class="mb-6 flex flex-wrap gap-2">
      <span class="badge bg-primary/10 text-primary">全部 {friends.length}</span>
      {categories.map((category) => <span class="badge">{category}</span>)}
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      {friends.map((friend) => <FriendCard {...friend} />)}
    </div>

    {sites.length > 0 && (
      <section class="mt-12">
        <div class="section-title">
          <div>
            <h2>常用站点</h2>
            <p>一些公开工具和资料入口。</p>
          </div>
        </div>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {
            sites.map((site) => (
              <a class="surface card-hover block p-5" href={site.url} target="_blank" rel="noreferrer">
                <span class="badge">{site.category}</span>
                <h3 class="mt-3 text-lg font-bold">{site.name}</h3>
                <p class="mt-2 text-sm leading-6 text-foreground/60">{site.description}</p>
              </a>
            ))
          }
        </div>
      </section>
    )}
  </section>
</BaseLayout>
