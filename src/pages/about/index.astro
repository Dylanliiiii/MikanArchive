---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getResume } from "../_data";

const resume = await getResume();
---

<BaseLayout title="我的" description="个人介绍、技能栈、项目入口和联系方式">
  <section class="container page-shell">
    <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <aside class="surface p-5 sm:p-6">
        <p class="text-sm font-semibold text-primary">我的</p>
        <h1 class="mt-3 text-3xl font-black tracking-normal sm:text-4xl">{resume.name}</h1>
        <p class="mt-3 text-lg leading-8 text-foreground/70">{resume.headline}</p>
        {resume.location && <p class="mt-3 text-sm text-foreground/55">{resume.location}</p>}
        <div class="mt-5 flex flex-wrap gap-2">
          {(resume.links ?? []).map((link) => <a class="button-outline" href={link.url} target="_blank" rel="noreferrer">{link.label}</a>)}
        </div>
      </aside>

      <div class="space-y-6">
        {resume.summary && (
          <section class="surface p-5 sm:p-6">
            <h2 class="text-xl font-bold">介绍</h2>
            <p class="mt-3 text-sm leading-7 text-foreground/70">{resume.summary}</p>
          </section>
        )}

        <section class="surface p-5 sm:p-6">
          <h2 class="text-xl font-bold">技能栈</h2>
          <div class="mt-4 flex flex-wrap gap-2">
            {(resume.skills ?? []).map((skill) => <span class="badge bg-secondary/15 text-sky-700">{skill}</span>)}
          </div>
        </section>

        <section class="surface p-5 sm:p-6">
          <h2 class="text-xl font-bold">项目入口</h2>
          <div class="mt-4 grid gap-3">
            {
              (resume.projects ?? []).map((project) => (
                <a class="surface-plain block p-4 transition hover:border-primary/40" href={project.url ?? "#"} target={project.url ? "_blank" : undefined} rel={project.url ? "noreferrer" : undefined}>
                  <h3 class="font-bold">{project.name}</h3>
                  <p class="mt-1 text-sm leading-6 text-foreground/60">{project.description}</p>
                </a>
              ))
            }
          </div>
        </section>

        <section class="surface p-5 sm:p-6">
          <h2 class="text-xl font-bold">联系方式</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {
              (resume.contacts ?? []).map((contact) => (
                <div class="surface-plain p-4">
                  <p class="text-xs text-foreground/50">{contact.label}</p>
                  <p class="mt-1 break-words text-sm font-semibold">{contact.value}</p>
                </div>
              ))
            }
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
