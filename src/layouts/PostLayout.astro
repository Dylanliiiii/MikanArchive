---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/utils/paths";

type Frontmatter = {
  title: string;
  description: string;
  published?: Date | string;
  updated?: Date | string;
  category?: string;
  tags?: string[];
  cover?: string;
};

interface Props {
  frontmatter: Frontmatter;
  readingTime?: string;
}

const { frontmatter, readingTime = "约 1 分钟" } = Astro.props;
const formatDate = (value?: Date | string) =>
  value
    ? new Intl.DateTimeFormat("zh-CN", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit"
      }).format(new Date(value))
    : "";
---

<BaseLayout title={frontmatter.title} description={frontmatter.description} showReadingProgress>
  <article class="narrow-container page-shell">
    <header class="surface mb-8 overflow-hidden">
      {
        frontmatter.cover && (
          <img src={withBase(frontmatter.cover)} alt="" class="h-56 w-full object-cover sm:h-72" loading="eager" />
        )
      }
      <div class="p-5 sm:p-8">
        <div class="mb-4 flex flex-wrap gap-2">
          {frontmatter.category && <span class="badge bg-primary/10 text-primary">{frontmatter.category}</span>}
          <span class="badge">{readingTime}</span>
          {frontmatter.published && <time class="badge" datetime={String(frontmatter.published)}>{formatDate(frontmatter.published)}</time>}
        </div>
        <h1 class="text-balance text-3xl font-bold leading-tight tracking-normal sm:text-4xl">{frontmatter.title}</h1>
        <p class="mt-4 text-base leading-8 text-foreground/70">{frontmatter.description}</p>
        {
          frontmatter.tags && frontmatter.tags.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-2">
              {frontmatter.tags.map((tag) => (
                <span class="badge">#{tag}</span>
              ))}
            </div>
          )
        }
      </div>
    </header>

    <div class="grid gap-6 lg:grid-cols-[1fr_12rem]">
      <div class="surface p-5 sm:p-8">
        <div class="prose prose-neutral max-w-none prose-mikan">
          <slot />
        </div>
      </div>
      <aside class="hidden lg:block">
        <div class="surface sticky top-24 p-4 text-sm text-foreground/60">
          <p class="font-semibold text-foreground">阅读索引</p>
          <p class="mt-2 leading-6">目录将随内容结构逐步增强。当前页面保留克制阅读宽度和进度条。</p>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>
