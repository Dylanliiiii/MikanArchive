---
import type { MarkdownHeading } from "astro";
import FloatingControls from "@/components/controls/FloatingControls.astro";
import FocusedBreadcrumb from "@/components/layout/FocusedBreadcrumb.astro";
import Footer from "@/components/layout/Footer.astro";
import Navbar from "@/components/layout/Navbar.astro";
import SidebarTOC from "@/components/widget/SidebarTOC.astro";
import { siteConfig } from "@/config";
import Layout from "./Layout.astro";

import "@/styles/expressive-code.css";
import "@/styles/markdown.css";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	postSlug?: string;
	postCategory?: string;
	headings?: MarkdownHeading[];
	bannerPostMeta?: {
		title: string;
		published: Date;
		updated?: Date;
		words?: number;
		minutes?: number;
	};
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	postSlug,
	headings = [],
} = Astro.props;

const isPostPage = Boolean(postSlug);
const showArticleTOC = isPostPage && headings.length > 0;
const navbarWidthFull = siteConfig.navbar.widthFull ?? false;
---

<Layout
	title={title}
	banner={banner}
	description={description}
	lang={lang}
	setOGTypeArticle={setOGTypeArticle}
	postSlug={postSlug}
	contentOnly
>
	<slot slot="head" name="head" />

	<div
		id="top-row"
		class:list={[
			"sticky top-0 left-0 right-0 z-80 mx-auto pointer-events-none mikan-glass-top-row",
			navbarWidthFull ? "w-full" : "w-full xl:w-[92vw] max-w-(--page-width) px-0 md:px-4",
		]}
	>
		<div id="navbar-wrapper" class="pointer-events-auto">
			<Navbar />
		</div>
	</div>

	<div id="focused-layout-marker" class="focused-page-shell relative w-full">
		<div id="banner-overlay-container" class="hidden"></div>
		<div id="banner-dim-container" class="hidden"></div>
		<div id="left-sidebar-dynamic" class="hidden transition-swup-fade"></div>
		<div id="right-sidebar-dynamic" class="hidden transition-swup-fade"></div>

		<div
			id="main-grid"
			class:list={[
				"focused-page-grid mx-auto grid w-full max-w-(--page-width) gap-4 px-3 pb-8 pt-4 md:px-6 md:pt-6",
				showArticleTOC ? "xl:grid-cols-[minmax(0,1fr)_17rem]" : "grid-cols-1",
			]}
			data-sidebar-position="none"
		>
			<div class="min-w-0">
				<main
					id="swup-container"
					class="transition-main"
				>
					<h1 class="sr-only">{title}</h1>
					<div id="grid-class-carrier" data-grid-class="grid-cols-1" class="hidden"></div>
					<div id="content-wrapper" class="onload-animation transition-leaving">
						<FocusedBreadcrumb title={title} />
						<slot />
					</div>
				</main>
			</div>

			{showArticleTOC && (
				<aside id="article-toc-wrapper" class="focused-article-toc hidden xl:block">
					<div class="focused-article-toc__sticky">
						<SidebarTOC headings={headings} />
					</div>
				</aside>
			)}

			<div class:list={["footer onload-animation mt-8", showArticleTOC ? "xl:col-span-2" : ""]}>
				<Footer />
			</div>
		</div>
	</div>

	<FloatingControls headings={headings} />
</Layout>

<style>
	.focused-page-shell {
		min-height: calc(100vh - 4.5rem);
	}

	:global(body.sticky-navbar) .focused-page-shell {
		padding-top: 6.35rem;
	}

	.focused-page-grid {
		align-items: start;
	}

	.focused-article-toc {
		min-width: 0;
		align-self: stretch;
	}

	.focused-article-toc__sticky {
		position: sticky;
		top: 6rem;
	}

	@media (min-width: 1280px) {
		.focused-page-grid:has(.focused-article-toc) {
			max-width: min(var(--page-width), 92vw);
		}
	}
</style>

<script>
	function enforceFocusedLayout() {
		const marker = document.getElementById("focused-layout-marker");
		if (!marker) return;

		document.body.dataset.contentOnly = "true";
		document.body.classList.remove("enable-banner", "is-home", "lg:is-home");
		document.body.classList.add("no-banner-layout");
	}

	enforceFocusedLayout();
	document.addEventListener("astro:page-load", enforceFocusedLayout);
	document.addEventListener("swup:contentReplaced", enforceFocusedLayout);
</script>
