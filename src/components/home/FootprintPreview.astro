---
interface UpdateItem {
  date: string;
  title: string;
  description: string;
  type?: string;
}

interface TimelineItem {
  date: string;
  title: string;
  description: string;
  category?: string;
}

interface Props {
  updates?: UpdateItem[];
  timeline?: TimelineItem[];
}

const { updates = [], timeline = [] } = Astro.props;
const latest = updates[0] ?? timeline[0];
---

<section class="container py-10">
  <div class="grid gap-4 lg:grid-cols-[0.9fr_1.1fr]">
    <div class="surface p-5">
      <div class="section-title mb-0">
        <div>
          <h2>足迹预览</h2>
          <p>最近一次让收藏馆变得更完整的更新。</p>
        </div>
      </div>
      {
        latest ? (
          <div class="mt-5 rounded-lg border border-border/70 bg-white/70 p-4">
            <time class="badge" datetime={latest.date}>{latest.date}</time>
            <h3 class="mt-3 text-xl font-bold">{latest.title}</h3>
            <p class="mt-2 text-sm leading-6 text-foreground/70">{latest.description}</p>
          </div>
        ) : (
          <p class="mt-5 text-sm text-foreground/60">还没有记录。</p>
        )
      }
    </div>
    <div class="surface p-5">
      <h2 class="text-xl font-bold">近期时间线</h2>
      <div class="mt-4 space-y-4">
        {
          timeline.slice(0, 3).map((item) => (
            <div class="border-l-2 border-primary/25 pl-4">
              <time class="text-xs text-foreground/50" datetime={item.date}>{item.date}</time>
              <p class="mt-1 font-semibold">{item.title}</p>
              <p class="mt-1 text-sm leading-6 text-foreground/60">{item.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
