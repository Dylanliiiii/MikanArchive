---
import PostCard from "@/components/cards/PostCard.astro";

interface PostItem {
  title: string;
  description: string;
  href: string;
  category?: string;
  tags?: string[];
  published?: string;
}

interface Props {
  posts?: PostItem[];
}

const { posts = [] } = Astro.props;
---

<section class="container py-10">
  <div class="section-title">
    <div>
      <h2>最近文章</h2>
      <p>教程、笔记和排错记录先从这里进入。</p>
    </div>
    <a class="button-ghost" href="/posts/">全部文章</a>
  </div>
  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {
      posts.slice(0, 3).map((post) => (
        <PostCard {...post} />
      ))
    }
  </div>
</section>
