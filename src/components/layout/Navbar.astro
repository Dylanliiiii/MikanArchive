---
import { Picture } from "astro:assets";
import * as path from "node:path";
import type { ImageMetadata } from "astro";
import { Icon } from "astro-icon/components";
import DisplaySettings from "@/components/controls/DisplaySettingsIntegrated.svelte";
import LightDarkSwitch from "@/components/controls/LightDarkSwitch.svelte";
import Search from "@/components/controls/Search.svelte";
import MusicPlayer from "@/components/features/MusicPlayer.astro";
import { backgroundWallpaper, navBarConfig, siteConfig } from "@/config";
import { musicPlayerConfig } from "@/config/musicConfig";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import type { NavBarLink } from "@/types/config";
import { getFallbackFormat, getImageFormats } from "@/utils/image-utils";
import { isHomePage } from "@/utils/layout-utils";
import { url } from "@/utils/url-utils";
import DropdownMenu from "./DropdownMenu.astro";
import NavMenuPanel from "./NavMenuPanel.astro";

const className = Astro.props.class;

// 获取导航栏透明模式配置
const navbarTransparentMode =
	backgroundWallpaper.mode === "banner"
		? backgroundWallpaper.common?.navbar?.transparentMode || "semi"
		: "semi";

// 获取导航栏毛玻璃效果配置
const navbarEnableBlur =
	backgroundWallpaper.mode === "banner"
		? (backgroundWallpaper.common?.navbar?.enableBlur ?? true)
		: false;

// 获取导航栏模糊度
const navbarBlur =
	backgroundWallpaper.mode === "banner"
		? (backgroundWallpaper.common?.navbar?.blur ?? 20)
		: 0;

// 获取导航栏标题，如果没有设置则使用 siteConfig.title
const navbarTitle = siteConfig.navbar.title || siteConfig.title;

// 获取导航栏宽度配置
const navbarWidthFull = siteConfig.navbar.widthFull ?? false;
const navbarMenuAlign = siteConfig.navbar.menuAlign ?? "center";
const isNavbarMenuCentered = navbarMenuAlign === "center";

// 检查是否为首页
const isHomePageCheck = isHomePage(Astro.url.pathname);
const currentPath = Astro.url.pathname;

// 检查是否有任何显示设置可用
const showThemeColor = !siteConfig.themeColor.fixed;
const hasDisplaySettings = showThemeColor;

// 根据 siteConfig.pages 过滤导航栏链接
const pages = siteConfig.pages;

function isPageEnabled(link: NavBarLink): boolean {
	if (!link.pageKey) return true;
	return pages[link.pageKey as keyof typeof pages] !== false;
}

function filterLinks(link: NavBarLink): NavBarLink | null {
	if (!link.children) {
		return isPageEnabled(link) ? link : null;
	}

	const filteredChildren = link.children.filter(isPageEnabled);

	if (filteredChildren.length === 0) return null;
	if (filteredChildren.length === 1) return filteredChildren[0];
	return { ...link, children: filteredChildren };
}

let links: NavBarLink[] = navBarConfig.links
	.map(filterLinks)
	.filter((link): link is NavBarLink => link !== null);

function normalizeNavPath(pathname: string): string {
	const baseUrl = import.meta.env.BASE_URL || "/";
	const withoutBase =
		baseUrl !== "/" && pathname.startsWith(baseUrl)
			? pathname.slice(baseUrl.length - 1)
			: pathname;
	const normalized = withoutBase.split("?")[0]?.replace(/\/+$/, "") || "/";
	return normalized === "" ? "/" : normalized;
}

function isNavLinkActive(link: NavBarLink, pathname = currentPath): boolean {
	if (link.children?.some((child) => isNavLinkActive(child, pathname))) {
		return true;
	}

	if (link.external || link.url === "#") return false;

	const current = normalizeNavPath(pathname);
	const target = normalizeNavPath(url(link.url));

	if (target === "/") return current === "/";
	return current === target || current.startsWith(`${target}/`);
}

// 处理导航栏 Logo 图片
const logoValue = siteConfig.navbar.logo?.value || "";
const isLocalSrcLogo =
	siteConfig.navbar.logo?.type === "image" &&
	logoValue &&
	!logoValue.startsWith("/") &&
	!logoValue.startsWith("http");
let logoImg: ImageMetadata | null = null;

if (isLocalSrcLogo) {
	const files = import.meta.glob<ImageMetadata>(
		"../../**/*.{png,jpg,jpeg,webp,avif,gif,svg}",
		{ import: "default" },
	);
	const normalizedPath = path
		.normalize(path.join("../../", logoValue))
		.replace(/\\/g, "/");
	const file = files[normalizedPath];
	if (file) {
		logoImg = await file();
	}
}
---
<div id="navbar" class="z-50" style={`--navbar-glass-blur: ${navbarBlur}px; --navbar-scroll-progress: 0;`} data-transparent-mode={navbarTransparentMode} data-enable-blur={String(navbarEnableBlur)} data-is-home={isHomePageCheck} data-full-width={navbarWidthFull} data-current-path={currentPath}>
    <div class:list={[
        className,
        "navbar-shell overflow-visible! h-18 px-4"
    ]}>
        <div class="navbar-inner mx-auto h-full w-full max-w-(--page-width) grid grid-cols-[auto_minmax(0,1fr)_auto] items-center">
            <a href={url('/')} class="navbar-brand btn-plain scale-animation rounded-lg h-13 px-5 font-bold active:scale-95">
                <div class:list={[
                    "navbar-brand-content flex flex-row items-center text-md",
                    siteConfig.navbar.followTheme ? "text-(--primary)" : "dark:text-white text-black"
                ]} style="font-family: var(--font-navbar-title, inherit)">
                    <span class="navbar-brand-logo" aria-hidden="true">
                                    {siteConfig.navbar.logo?.type === "icon" ? (
                                        <Icon is:inline name={siteConfig.navbar.logo.value || "material-symbols:home-pin-outline"} class="text-[1.75rem]" />
                                    ) : siteConfig.navbar.logo?.type === "image" && logoImg ? (
                                        <Picture
                                            src={logoImg}
                                            alt={siteConfig.navbar.logo.alt || siteConfig.title}
                                            class="h-7 w-7 object-contain"
                                            formats={getImageFormats()}
                                            fallbackFormat={getFallbackFormat()}
                                            widths={[28, 56]}
                                            loading="eager"
                                            fetchpriority="high"
                                        />
                                    ) : siteConfig.navbar.logo?.type === "image" ? (
                                        <img src={url(siteConfig.navbar.logo.value)} alt={siteConfig.navbar.logo.alt || siteConfig.title} class="h-7 w-7 object-contain" fetchpriority="high" />
                                    ) : siteConfig.navbar.logo?.type === "url" ? (
                                        <img src={siteConfig.navbar.logo.value} alt={siteConfig.navbar.logo.alt || siteConfig.title} class="h-7 w-7 object-contain" fetchpriority="high" />
                                    ) : (
                                        <Icon is:inline name="material-symbols:home-pin-outline" class="text-[1.75rem]" />
                                    )}
                    </span>
                    <span class="navbar-brand-text">{navbarTitle}</span>
                </div>
            </a>
            <div class:list={[
                "navbar-navigation",
                "hidden lg:flex items-center space-x-1 col-start-2",
                isNavbarMenuCentered
                    ? "justify-center"
                    : "justify-start pl-2"
            ]}>
                {links.map((l) => {
                    return <DropdownMenu link={l} currentPath={currentPath} isActive={isNavLinkActive(l)} />;
                })}
            </div>
            <div class="navbar-actions flex col-start-3 justify-self-end">
                <!--<SearchPanel client:load>-->
                <Search
                    client:load
                />
                {musicPlayerConfig.showInNavbar && (
                    <button aria-label={i18n(I18nKey.music)} class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90" id="music-player-switch">
                        <Icon is:inline name="material-symbols:music-note-rounded" class="text-[1.25rem]"></Icon>
                    </button>
                )}
                {backgroundWallpaper.playerEnable && backgroundWallpaper.mode !== "none" && (
                    <button
                        aria-label={i18n(I18nKey.videoPlay)}
                        class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90"
                        id="bg-player-toggle"
                        data-i18n-play={i18n(I18nKey.videoPlay)}
                        data-i18n-pause={i18n(I18nKey.videoPause)}
                    >
                        <Icon is:inline name="material-symbols:play-arrow-rounded" class="text-[1.5rem]" />
                    </button>
                )}
                {hasDisplaySettings && (
                        <button aria-label="Display Settings" class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90" id="display-settings-switch">
                            <Icon is:inline name="material-symbols:palette-outline" class="text-[1.25rem]"></Icon>
                        </button>
                )}
                {/* @ts-ignore */}
                <LightDarkSwitch client:load></LightDarkSwitch>
                <button aria-label="Menu" name="Nav Menu" class="btn-plain scale-animation rounded-lg w-11 h-11 active:scale-90 lg:hidden!" id="nav-menu-switch">
                    <Icon is:inline name="material-symbols:menu-rounded" class="text-[1.25rem]"></Icon>
                </button>
            </div>
        </div>
        {musicPlayerConfig.showInNavbar && (
            <div id="music-nav-panel" class="float-panel float-panel-closed absolute transition-all right-16 p-2 pt-4.5 w-80 z-50">
                <MusicPlayer />
            </div>
        )}
        <NavMenuPanel links={links}></NavMenuPanel>
        <DisplaySettings client:load></DisplaySettings>
    </div>
</div>

<script>
function loadButtonScript() {
    let settingBtn = document.getElementById("display-settings-switch");
    if (settingBtn) {
        settingBtn.onclick = function () {
            let settingPanel = document.getElementById("display-setting");
            if (settingPanel) {
                settingPanel.classList.toggle("float-panel-closed");
            }
        };
    }

    let menuBtn = document.getElementById("nav-menu-switch");
    if (menuBtn) {
        menuBtn.onclick = function () {
            let menuPanel = document.getElementById("nav-menu-panel");
            if (menuPanel) {
                menuPanel.classList.toggle("float-panel-closed");
            }
        };
    }

    let musicBtn = document.getElementById("music-player-switch");
    if (musicBtn) {
        musicBtn.onclick = function () {
            let musicPanel = document.getElementById("music-nav-panel");
            if (musicPanel) {
                musicPanel.classList.toggle("float-panel-closed");
            }
        };
    }

    // 背景视频播放器控制按钮
    let bgPlayerBtn = document.getElementById("bg-player-toggle");
    if (bgPlayerBtn) {
        bgPlayerBtn.onclick = function () {
            window.dispatchEvent(new CustomEvent("bg-player-toggle"));
        };
        window.addEventListener("bg-player-state-change", function (e) {
            var ce = e as CustomEvent;
            var playing = ce.detail && ce.detail.playing;
            var i18nPlay = bgPlayerBtn!.getAttribute("data-i18n-play") ?? "";
            var i18nPause = bgPlayerBtn!.getAttribute("data-i18n-pause") ?? "";
            var label = playing ? i18nPause : i18nPlay;
            bgPlayerBtn!.innerHTML = playing
                ? '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M16 19q-.825 0-1.412-.587T14 17V7q0-.825.588-1.412T16 5t1.413.588T18 7v10q0 .825-.587 1.413T16 19m-8 0q-.825 0-1.412-.587T6 17V7q0-.825.588-1.412T8 5t1.413.588T10 7v10q0 .825-.587 1.413T8 19"/></svg>'
                : '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M8 17.175V6.825q0-.425.3-.713t.7-.287q.125 0 .263.037t.262.113l8.15 5.175q.225.15.338.375t.112.475t-.112.475t-.338.375l-8.15 5.175q-.125.075-.262.113T9 18.175q-.4 0-.7-.288t-.3-.712"/></svg>';
            bgPlayerBtn!.setAttribute("title", label);
            bgPlayerBtn!.setAttribute("aria-label", label);
        });
        // 切换壁纸模式时隐藏/显示播放按钮
        window.addEventListener("wallpaperModeChange", function (e) {
            var ce = e as CustomEvent;
            var mode = ce.detail && ce.detail.mode;
            bgPlayerBtn!.style.display = mode === "none" ? "none" : "";
        });
        // Swup 导航时同步播放按钮状态（BackgroundPlayer 可能被重建，也可能持久存在）
        function syncBgPlayerBtn() {
            var playing = document.documentElement.hasAttribute("data-bg-video-playing");
            var i18nPlay = bgPlayerBtn!.getAttribute("data-i18n-play") ?? "";
            var i18nPause = bgPlayerBtn!.getAttribute("data-i18n-pause") ?? "";
            var label = playing ? i18nPause : i18nPlay;
            bgPlayerBtn!.innerHTML = playing
                ? '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M16 19q-.825 0-1.412-.587T14 17V7q0-.825.588-1.412T16 5t1.413.588T18 7v10q0 .825-.587 1.413T16 19m-8 0q-.825 0-1.412-.587T6 17V7q0-.825.588-1.412T8 5t1.413.588T10 7v10q0 .825-.587 1.413T8 19"/></svg>'
                : '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M8 17.175V6.825q0-.425.3-.713t.7-.287q.125 0 .263.037t.262.113l8.15 5.175q.225.15.338.375t.112.475t-.112.475t-.338.375l-8.15 5.175q-.125.075-.262.113T9 18.175q-.4 0-.7-.288t-.3-.712"/></svg>';
            bgPlayerBtn!.setAttribute("title", label);
            bgPlayerBtn!.setAttribute("aria-label", label);
        }
        if (window.swup && window.swup.hooks) {
            window.swup.hooks.on("content:replace", syncBgPlayerBtn);
        } else {
            document.addEventListener("swup:enable", function () {
                window.swup.hooks.on("content:replace", syncBgPlayerBtn);
            });
        }
    }

    let themeSwitchBtn = document.getElementById("scheme-switch");
    if (themeSwitchBtn) {
        themeSwitchBtn.onclick = function () {
            let themePanel = document.getElementById("theme-mode-panel");
            if (themePanel) {
                themePanel.classList.toggle("float-panel-closed");
            }
        };
    }

    document.addEventListener("click", function(event) {
        const panels = ["display-setting", "nav-menu-panel", "music-nav-panel", "theme-mode-panel"];
        const buttons = ["display-settings-switch", "nav-menu-switch", "music-player-switch", "scheme-switch"];

        panels.forEach((id, index) => {
            const panel = document.getElementById(id);
            const button = document.getElementById(buttons[index]);
            if (panel && button && !panel.classList.contains("float-panel-closed")) {
                if (event.target instanceof Node && !panel.contains(event.target) && !button.contains(event.target)) {
                    panel.classList.add("float-panel-closed");
                }
            }
        });
    });
}

loadButtonScript();

// 为semifull模式添加滚动检测逻辑
function initSemifullScrollDetection() {
    const navbar = document.getElementById('navbar');
    if (!navbar) return;

    const transparentMode = navbar.getAttribute('data-transparent-mode');
    if (transparentMode !== 'semifull') return;

    // 无论首页/非首页，semifull 都由滚动位置决定是否进入 scrolled 状态
    // 先移除之前的滚动监听器，避免重复绑定
    if (window.semifullScrollHandler) {
        window.removeEventListener('scroll', window.semifullScrollHandler as () => void);
        window.semifullScrollHandler = undefined;
    }

    // 初始状态不强制加 scrolled，保持透明；滚动后再切换
    navbar.classList.remove('scrolled');

    let ticking = false;

    function updateNavbarState() {
        if (document.documentElement.classList.contains('is-page-transitioning')) {
            navbar!.classList.remove('scrolled');
            ticking = false;
            return;
        }

        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        const threshold = 50; // 滚动阈值，可以根据需要调整
        // 使用批量DOM操作优化性能
        if (scrollTop > threshold) {
            navbar!.classList.add('scrolled');
        } else {
            navbar!.classList.remove('scrolled');
        }

        ticking = false;
    }

    function requestTick() {
        if (!ticking) {
            requestAnimationFrame(updateNavbarState);
            ticking = true;
        }
    }

    // 移除之前的滚动事件监听器（如果存在）
    if (window.semifullScrollHandler) {
        window.removeEventListener('scroll', window.semifullScrollHandler as () => void);
    }

    // 保存新的事件处理器引用
    window.semifullScrollHandler = requestTick as unknown as (() => void);

    // 监听滚动事件
    window.addEventListener('scroll', requestTick, { passive: true });

    // 初始化状态
    updateNavbarState();
}

// 将函数暴露到全局对象，供页面切换时调用
window.initSemifullScrollDetection = initSemifullScrollDetection;

// 页面加载完成后初始化滚动检测
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSemifullScrollDetection);
} else {
    initSemifullScrollDetection();
}

function initLiquidNavbarScroll() {
    const navbar = document.getElementById("navbar");
    if (!navbar) return;

    const maxScroll = 160;
    let ticking = false;

    function updateLiquidNavbar() {
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop || 0;
        const progress = Math.min(1, Math.max(0, scrollTop / maxScroll));
        const rootFontSize = Number.parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
        const viewportWidth = window.innerWidth || document.documentElement.clientWidth || 0;
        const parentWidth = navbar!.parentElement?.getBoundingClientRect().width || viewportWidth;
        const isMobile = viewportWidth < 768;
        const isTablet = viewportWidth >= 768 && viewportWidth <= 1180;
        const targetWidth = isMobile
            ? Math.max(0, parentWidth - 8)
            : isTablet
                ? Math.max(0, parentWidth - viewportWidth * 0.07)
                : Math.min(64 * rootFontSize, viewportWidth * 0.84, parentWidth);
        const currentWidth = parentWidth - (parentWidth - targetWidth) * progress;
        const fullHeight = (isMobile ? 4.35 : 4.8) * rootFontSize;
        const compactHeight = (isMobile ? 4.05 : 4.18) * rootFontSize;
        const currentHeight = fullHeight - (fullHeight - compactHeight) * progress;
        const shellPadding = (isMobile ? 0.7 : 1) * rootFontSize - (isMobile ? 0.08 : 0.28) * rootFontSize * progress;
        const brandTextWidth = (isMobile ? 6.7 : 7.9) * rootFontSize * (1 - progress);
        const brandTextOpacity = Math.max(0, 1 - Math.min(1, progress * 1.35));
        const controlHeight = (isMobile ? 2.6 : 2.85) * rootFontSize;
        const searchFullWidth = 11.2 * rootFontSize;
        const searchWidth = searchFullWidth - (searchFullWidth - controlHeight) * progress;

        navbar!.style.setProperty("--navbar-scroll-progress", progress.toFixed(3));
        navbar!.style.setProperty("--mikan-navbar-compact-progress", progress.toFixed(3));
        navbar!.style.setProperty("--mikan-navbar-shell-width", `${currentWidth.toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-current-height", `${currentHeight.toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-shell-padding", `${shellPadding.toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-brand-padding", `${(1.25 * rootFontSize - 0.58 * rootFontSize * progress).toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-brand-text-width", `${brandTextWidth.toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-brand-text-opacity", brandTextOpacity.toFixed(3));
        navbar!.style.setProperty("--mikan-navbar-brand-gap", `${(0.55 * rootFontSize * (1 - progress)).toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-brand-logo-shift", `${(0.12 * rootFontSize * progress).toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-brand-text-shift", `${(-0.38 * rootFontSize * progress).toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-navigation-shift", `${(-0.42 * rootFontSize * progress).toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-actions-gap", `${((0.03 + 0.08 * progress) * rootFontSize).toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-actions-inset", `${((0.55 + 0.18 * progress) * rootFontSize).toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-search-size", `${controlHeight.toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-search-width", `${searchWidth.toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-current-blur", `${(22 + 8 * progress).toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-current-saturate", (1.2 + 0.47 * progress).toFixed(3));
        navbar!.style.setProperty("--mikan-navbar-current-contrast", (1 + 0.05 * progress).toFixed(3));
        navbar!.style.setProperty("--mikan-navbar-top-glow-alpha", (0.34 + 0.3 * progress).toFixed(3));
        navbar!.style.setProperty("--mikan-navbar-start-alpha", (0.76 + 0.12 * progress).toFixed(3));
        navbar!.style.setProperty("--mikan-navbar-mid-alpha", (0.54 + 0.2 * progress).toFixed(3));
        navbar!.style.setProperty("--mikan-navbar-border-alpha", (0.68 + 0.22 * progress).toFixed(3));
        navbar!.style.setProperty("--mikan-navbar-inner-highlight-alpha", (0.5 + 0.36 * progress).toFixed(3));
        navbar!.style.setProperty("--mikan-navbar-inner-shadow-alpha", (0.08 + 0.16 * progress).toFixed(3));
        navbar!.style.setProperty("--mikan-navbar-shadow-y", `${(1.1 + 0.45 * progress).toFixed(2)}rem`);
        navbar!.style.setProperty("--mikan-navbar-shadow-blur", `${(3 + 1.3 * progress).toFixed(2)}rem`);
        navbar!.style.setProperty("--mikan-navbar-shadow-alpha", (0.14 + 0.09 * progress).toFixed(3));
        navbar!.style.setProperty("--mikan-navbar-reflection-height", `${(46 + 10 * progress).toFixed(2)}%`);
        navbar!.style.setProperty("--mikan-navbar-reflection-opacity", (0.34 + 0.46 * progress).toFixed(3));
        navbar!.style.setProperty("--mikan-navbar-reflection-shift", `${(0.14 * rootFontSize * progress).toFixed(2)}px`);
        navbar!.style.setProperty("--mikan-navbar-depth-opacity", (0.16 + 0.34 * progress).toFixed(3));
        navbar!.classList.toggle("is-liquid-compact", progress > 0.94);
        ticking = false;
    }

    function requestLiquidNavbarTick() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(updateLiquidNavbar);
    }

    window.removeEventListener("scroll", window.liquidNavbarScrollHandler as () => void);
    window.liquidNavbarScrollHandler = requestLiquidNavbarTick as unknown as (() => void);
    window.addEventListener("scroll", requestLiquidNavbarTick, { passive: true });
    window.addEventListener("resize", requestLiquidNavbarTick, { passive: true });
    updateLiquidNavbar();
}

window.initLiquidNavbarScroll = initLiquidNavbarScroll;

if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initLiquidNavbarScroll);
} else {
    initLiquidNavbarScroll();
}
</script>

{
    import.meta.env.PROD && (
        <script is:inline data-swup-ignore-script define:vars={{ scriptUrl: url('/pagefind/pagefind.js') }}>
            {/* 你的 loadPagefind 函数的完整内容放在这里 */}
            async function loadPagefind() {
                try {
                    const response = await fetch(scriptUrl, { method: 'HEAD' });
                    if (!response.ok) {
                        throw new Error(`Pagefind script not found: ${response.status}`);
                    }
                    const pagefind = await import(scriptUrl);
                    await pagefind.options({
                        excerptLength: 20
                    });
                    window.pagefind = pagefind;
                    document.dispatchEvent(new CustomEvent('pagefindready'));
                    console.log('Pagefind loaded and initialized successfully, event dispatched.');
                } catch (error) {
                    console.error('Failed to load Pagefind:', error);
                    window.pagefind = {
                        search: () => Promise.resolve({ results: [] }),
                        options: () => Promise.resolve(),
                    };
                    document.dispatchEvent(new CustomEvent('pagefindloaderror'));
                    console.log('Pagefind load error, event dispatched.');
                }
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', loadPagefind);
            } else {
                loadPagefind();
            }
        </script>
    )
}
