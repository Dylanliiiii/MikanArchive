---
import { Icon } from "astro-icon/components";
import { commentConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { formatDateToYYYYMMDD } from "@/utils/date-utils";
import { getCategoryUrl, getTagUrl } from "@/utils/url-utils";

export interface Props {
	published: Date;
	updated?: Date;
	category?: string;
	tags?: string[];
	hideUpdateDate?: boolean;
	hideTagsForMobile?: boolean;
	isHome?: boolean;
	className?: string;
	id?: string;
	words?: number;
	minutes?: number;
	showTags?: boolean;
	customPath?: string;
	pinned?: boolean;
	password?: boolean;
	shareTitle?: string;
	shareDescription?: string;
	shareUrl?: string;
}

const {
	published,
	updated,
	category,
	tags,
	hideUpdateDate,
	hideTagsForMobile,
	isHome,
	className = "",
	id,
	showTags = true,
	customPath,
	pinned,
	shareTitle,
	shareDescription = "",
	shareUrl,
} = Astro.props;

const path = customPath || (id ? `/posts/${id}` : "");
const hasTwikooPageViews =
	!isHome &&
	commentConfig.type === "twikoo" &&
	commentConfig.twikoo?.visitorCount &&
	id;
const hasWalinePageViews =
	!isHome &&
	commentConfig.type === "waline" &&
	commentConfig.waline?.visitorCount &&
	id;
const hasArtalkPageViews =
	!isHome &&
	commentConfig.type === "artalk" &&
	commentConfig.artalk?.visitorCount &&
	id;
const hasProviderPageViews =
	hasTwikooPageViews || hasWalinePageViews || hasArtalkPageViews;
const shouldShowPostActions = Boolean(!isHome && id && shareTitle);
const normalizedShareTitle = shareTitle || "";
const normalizedShareDescription = shareDescription || normalizedShareTitle;
const normalizedShareUrl = shareUrl || Astro.url.href;
---

<div
  class:list={[
    "post-meta-root flex flex-wrap text-neutral-500 dark:text-neutral-400 items-center gap-4 gap-x-4 gap-y-2",
    className,
  ]}
>
  <!-- pinned -->
  {
    pinned && (
      <div class="pinned-btn flex items-center gap-1 bg-(--btn-regular-bg) text-(--btn-content) rounded-md px-2 py-1.5 font-bold">
        <Icon is:inline name="material-symbols:pinboard" class="text-xl" />
        <span class="text-sm">{i18n(I18nKey.pinned)}</span>
      </div>
    )
  }

  <!-- publish date -->
  <div class="flex items-center">
    <div class="meta-icon">
      <Icon is:inline
        name="material-symbols:calendar-today-outline-rounded"
        class="text-xl"
      />
    </div>
    <span class="text-50 text-sm font-medium"
      >{formatDateToYYYYMMDD(published)}</span
    >
  </div>

  <!-- update date -->
  {
    !hideUpdateDate && updated && updated.getTime() !== published.getTime() && (
      <div class="flex items-center">
        <div class="meta-icon">
          <Icon is:inline
            name="material-symbols:edit-calendar-outline-rounded"
            class="text-xl"
          />
        </div>
        <span class="text-50 text-sm font-medium">
          {formatDateToYYYYMMDD(updated)}
        </span>
      </div>
    )
  }

  <!-- categories -->
  <div class="flex items-center">
    <div class="meta-icon">
      <Icon is:inline name="material-symbols:book-2-outline-rounded" class="text-xl" />
    </div>
    <div class="flex flex-row flex-nowrap items-center">
      <a
        href={getCategoryUrl(category || "")}
        aria-label={`View all posts in the ${category} category`}
        class="link-lg transition text-50 text-sm font-medium
                            hover:text-(--primary) dark:hover:text-(--primary) whitespace-nowrap"
      >
        {category || i18n(I18nKey.uncategorized)}
      </a>
    </div>
  </div>

   <!-- tags -->
   {
     showTags && (
       <div class:list={["items-center", {"flex": !hideTagsForMobile, "hidden md:flex": hideTagsForMobile}]}>
         <div class="meta-icon">
           <Icon is:inline name="material-symbols:tag-rounded" class="text-xl" />
         </div>
         <div class="flex flex-row flex-nowrap items-center">
           {(tags && tags.length > 0) && tags.map((tag, i) => (
             <div class:list={[{"hidden": i == 0}, "mx-1.5 text-(--meta-divider) text-sm"]}>/</div>
             <a href={getTagUrl(tag)} aria-label={`View all posts with the ${tag.trim()} tag`}
                class="link-lg transition text-50 text-sm font-medium
                             hover:text-(--primary) dark:hover:text-(--primary) whitespace-nowrap">
               {tag.trim()}
             </a>
           ))}
           {!(tags && tags.length > 0) && <div class="transition text-50 text-sm font-medium">{i18n(I18nKey.noTags)}</div>}
         </div>
       </div>
     )
   }

  <!-- 文章详情页浏览量：只展示真实统计服务，未配置时显示不可用 -->
  {
    shouldShowPostActions && (
      <div class:list={["post-meta-pageviews flex items-center", { "post-meta-pageviews--unavailable": !hasProviderPageViews }]}>
        <div class="meta-icon">
          <Icon is:inline
            name="material-symbols:visibility-outline-rounded"
            class="text-xl"
          />
        </div>
        <span class="text-50 text-sm font-medium mr-1">
          {i18n(I18nKey.pageViews)}
        </span>
        {hasTwikooPageViews && (
          <span class="text-50 text-sm font-medium" id="twikoo_visitors">
            {i18n(I18nKey.pageViewsLoading)}
          </span>
        )}
        {hasWalinePageViews && (
          <span class="text-50 text-sm font-medium waline-pageview-count" data-path={path}>
            {i18n(I18nKey.pageViewsLoading)}
          </span>
        )}
        {hasArtalkPageViews && (
          <span class="text-50 text-sm font-medium artalk-pv-count" data-path={path}>
            {i18n(I18nKey.pageViewsLoading)}
          </span>
        )}
        {!hasProviderPageViews && (
          <span class="text-50 text-sm font-medium">
            {i18n(I18nKey.pageViewsError)}
          </span>
        )}
      </div>
    )
  }

  {
    shouldShowPostActions && (
      <button
        type="button"
        class="post-meta-share-btn flex items-center text-50 text-sm font-medium transition hover:text-(--primary) active:scale-95"
        data-post-share-button
        data-post-share-url={normalizedShareUrl}
        data-post-share-title={normalizedShareTitle}
        data-post-share-description={normalizedShareDescription}
        aria-label={i18n(I18nKey.shareArticle)}
      >
        <div class="meta-icon">
          <Icon is:inline name="material-symbols:share" class="text-xl" />
        </div>
        <span>{i18n(I18nKey.shareArticle)}</span>
        <span
          class="ml-2 hidden rounded-md bg-(--btn-regular-bg) px-2 py-0.5 text-xs text-(--btn-content)"
          data-post-share-feedback
        >
          {i18n(I18nKey.copied)}
        </span>
      </button>
    )
  }
</div>

{
  shouldShowPostActions && (
    <script>
      let shareFeedbackTimer: ReturnType<typeof setTimeout> | undefined;

      function setShareFeedback(button: HTMLButtonElement, visible: boolean) {
        const feedback = button.querySelector("[data-post-share-feedback]");
        if (!feedback) return;

        feedback.classList.toggle("hidden", !visible);
      }

      async function copyPostShareUrl(button: HTMLButtonElement) {
        const shareUrl = button.dataset.postShareUrl || window.location.href;

        await navigator.clipboard.writeText(shareUrl);
        setShareFeedback(button, true);

        if (shareFeedbackTimer) {
          clearTimeout(shareFeedbackTimer);
        }
        shareFeedbackTimer = setTimeout(() => {
          setShareFeedback(button, false);
        }, 1800);
      }

      async function handlePostShareClick(event: Event) {
        const button = event.currentTarget as HTMLButtonElement;
        const shareUrl = button.dataset.postShareUrl || window.location.href;
        const shareTitle = button.dataset.postShareTitle || document.title;
        const shareDescription = button.dataset.postShareDescription || shareTitle;

        if (navigator.share) {
          try {
            await navigator.share({
              title: shareTitle,
              text: shareDescription,
              url: shareUrl,
            });
            return;
          } catch (error) {
            if (error instanceof DOMException && error.name === "AbortError") {
              return;
            }
          }
        }

        if (navigator.clipboard && typeof navigator.clipboard.writeText === "function") {
          await copyPostShareUrl(button);
        }
      }

      function initPostShareButtons() {
        const buttons = document.querySelectorAll<HTMLButtonElement>("[data-post-share-button]");

        buttons.forEach((button) => {
          if (button.dataset.postShareBound === "true") return;

          button.dataset.postShareBound = "true";
          button.addEventListener("click", handlePostShareClick);
        });
      }

      initPostShareButtons();
      document.addEventListener("DOMContentLoaded", initPostShareButtons);
      document.addEventListener("astro:page-load", initPostShareButtons);
      document.addEventListener("swup:contentReplaced", initPostShareButtons);
    </script>
  )
}
