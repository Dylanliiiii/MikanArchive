---
import { Icon } from "astro-icon/components";
import { getFocusedBreadcrumb } from "@/utils/focused-breadcrumb";
import { url } from "@/utils/url-utils";

interface Props {
	title?: string;
}

const { title = "" } = Astro.props;
const items = getFocusedBreadcrumb(Astro.url.pathname, title);
---

{items.length > 0 && (
	<nav class="focused-breadcrumb" aria-label="面包屑">
		<ol>
			{items.map((item, index) => (
				<li>
					{index > 0 && <span class="focused-breadcrumb__sep" aria-hidden="true">›</span>}
					{item.isCurrent ? (
						<span class="focused-breadcrumb__current" aria-current="page">
							<Icon is:inline name={item.icon} />
							<span>{item.label}</span>
						</span>
					) : (
						<a class="focused-breadcrumb__link" href={url(item.href)}>
							<Icon is:inline name={item.icon} />
							<span>{item.label}</span>
						</a>
					)}
				</li>
			))}
		</ol>
	</nav>
)}

<style>
	.focused-breadcrumb {
		position: relative;
		z-index: 12;
		margin: 0 0 1rem;
		color: var(--content-meta);
		font-size: 0.9rem;
	}

	.focused-breadcrumb ol {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.focused-breadcrumb li {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		min-width: 0;
	}

	.focused-breadcrumb__link,
	.focused-breadcrumb__current {
		display: inline-flex;
		align-items: center;
		gap: 0.38rem;
		min-height: 2.15rem;
		border-radius: 0.72rem;
		text-decoration: none;
	}

	.focused-breadcrumb__link {
		color: var(--content-meta);
		transition: color 160ms ease, background 160ms ease;
	}

	:root.dark .focused-breadcrumb__link {
		color: rgba(255, 255, 255, 0.68);
	}

	.focused-breadcrumb__link:hover,
	.focused-breadcrumb__link:focus-visible {
		color: var(--primary);
		outline: none;
	}

	.focused-breadcrumb__current {
		max-width: min(34rem, 70vw);
		color: var(--deep-text);
		font-weight: 760;
	}

	:root.dark .focused-breadcrumb__current {
		color: rgba(255, 255, 255, 0.86);
	}

	.focused-breadcrumb__current span:last-child {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.focused-breadcrumb svg {
		width: 1rem;
		height: 1rem;
		flex: 0 0 auto;
	}

	.focused-breadcrumb__sep {
		color: color-mix(in srgb, var(--content-meta) 58%, transparent);
	}

	:root.dark .focused-breadcrumb__sep {
		color: rgba(255, 255, 255, 0.42);
	}

	@media (max-width: 640px) {
		.focused-breadcrumb {
			margin-bottom: 0.85rem;
			font-size: 0.82rem;
		}

		.focused-breadcrumb__current {
			max-width: 62vw;
		}
	}
</style>
