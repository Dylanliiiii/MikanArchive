---
interface Props {
  title: string;
  url: string;
  category?: string;
  tags?: string[];
  note: string;
  featured?: boolean;
}

const { title, url, category = "资源", tags = [], note, featured = false } = Astro.props;
---

<a href={url} target="_blank" rel="noreferrer" class="surface card-hover block p-5">
  <div class="mb-3 flex items-center justify-between gap-3">
    <span class="badge bg-secondary/20 text-sky-700">{category}</span>
    {featured && <span class="badge bg-yellow-100 text-yellow-800">精选</span>}
  </div>
  <h3 class="line-clamp-2 text-lg font-bold leading-snug tracking-normal">{title}</h3>
  <p class="mt-2 line-clamp-4 text-sm leading-6 text-foreground/70">{note}</p>
  {
    tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {tags.slice(0, 4).map((tag) => (
          <span class="badge">#{tag}</span>
        ))}
      </div>
    )
  }
</a>
