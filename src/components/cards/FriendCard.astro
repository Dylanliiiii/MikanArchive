---
interface Props {
  name: string;
  url: string;
  avatar: string;
  description: string;
  category?: string;
  tags?: string[];
  featured?: boolean;
  status?: string;
}

const {
  name,
  url,
  avatar,
  description,
  category = "友邻",
  tags = [],
  featured = false,
  status = "active"
} = Astro.props;
---

<a href={url} target="_blank" rel="noreferrer" class="surface card-hover group flex min-w-0 gap-4 p-4">
  <img src={avatar} alt={`${name} 的头像`} class="h-16 w-16 shrink-0 rounded-lg border border-border bg-muted object-cover" loading="lazy" />
  <div class="min-w-0 flex-1">
    <div class="flex min-w-0 flex-wrap items-center gap-2">
      <h3 class="max-w-full truncate text-base font-bold tracking-normal">{name}</h3>
      <span class="badge">{category}</span>
      {featured && <span class="badge bg-primary/10 text-primary">推荐</span>}
      {status === "unavailable" && <span class="badge bg-neutral-200 text-neutral-600">暂不可达</span>}
    </div>
    <p class="mt-2 line-clamp-2 text-sm leading-6 text-foreground/70">{description}</p>
    {
      tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {tags.slice(0, 3).map((tag) => (
            <span class="badge">#{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</a>
